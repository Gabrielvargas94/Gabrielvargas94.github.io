{
  "name": "gabrielvargas94.github.io",
  "type": "module",
  "version": "0.0.1",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=22",
    "pnpm": ">=10"
  },
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro build && node scripts/build-cv-json.mjs && node scripts/build-llms.mjs && node scripts/build-og.mjs && node scripts/build-cv-pdf.mjs",
    "preview": "astro preview",
    "astro": "astro",
    "typecheck": "astro check",
    "lint": "pnpm run lint:js && pnpm run lint:css",
    "lint:js": "eslint .",
    "lint:js:fix": "eslint . --fix",
    "lint:css": "stylelint \"src/**/*.scss\"",
    "lint:css:fix": "stylelint --fix \"src/**/*.scss\"",
    "format": "prettier --write \"**/*.{ts,tsx,mjs,js,astro,json,md,scss}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,mjs,js,astro,json,md,scss}\"",
    "test:a11y": "playwright test tests/a11y.spec.ts",
    "test:seo": "playwright test tests/seo.spec.ts",
    "test:artifacts": "playwright test tests/artifacts.spec.ts",
    "test:i18n": "playwright test tests/i18n.spec.ts",
    "test:lhci": "lhci autorun",
    "test:links": "linkinator dist --silent --skip 'linkedin.com|github.com'",
    "test": "pnpm run test:a11y && pnpm run test:seo && pnpm run test:artifacts && pnpm run test:i18n",
    "validate:cv": "node scripts/validate-cv-json.mjs",
    "inspect:jsonld": "node scripts/inspect-jsonld.mjs"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/mdx": "^5.0.6",
    "@astrojs/partytown": "^2.1.7",
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.2",
    "astro": "^6.3.7",
    "astro-compress": "^2.4.1",
    "astro-icon": "^1.1.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@eslint/js": "^10.0.1",
    "@fontsource/newsreader": "^5.2.10",
    "@iconify-json/lucide": "^1.2.109",
    "@iconify-json/simple-icons": "^1.2.83",
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.60.0",
    "@resvg/resvg-js": "^2.6.2",
    "@types/node": "^22.19.19",
    "@typescript-eslint/parser": "^8.59.4",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "eslint": "^10.4.0",
    "eslint-plugin-astro": "^1.7.0",
    "http-server": "^14.1.1",
    "js-yaml": "^4.1.1",
    "linkinator": "^7.6.1",
    "playwright": "^1.60.0",
    "prettier": "^3.8.3",
    "prettier-plugin-astro": "^0.14.1",
    "sass": "^1.100.0",
    "satori": "^0.26.0",
    "satori-html": "^0.3.2",
    "stylelint": "^17.12.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "typescript": "~5.9",
    "typescript-eslint": "^8.59.4"
  },
  "optionalDependencies": {
    "@rollup/rollup-darwin-arm64": "^4.60.4",
    "@rollup/rollup-darwin-x64": "^4.60.4",
    "@rollup/rollup-linux-x64-gnu": "^4.60.4",
    "@rollup/rollup-win32-arm64-msvc": "^4.60.4",
    "@rollup/rollup-win32-x64-msvc": "^4.60.4"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "esbuild",
      "sharp"
    ],
    "supportedArchitectures": {
      "os": [
        "win32",
        "linux",
        "darwin"
      ],
      "cpu": [
        "x64",
        "arm64"
      ]
    }
  }
}
