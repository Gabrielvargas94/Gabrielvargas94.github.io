# Normalize line endings to LF on commit (Windows shows CRLF locally, repo stays clean).
* text=auto eol=lf

# Force LF for source files even on Windows checkout.
*.astro    text eol=lf
*.ts       text eol=lf
*.tsx      text eol=lf
*.mjs      text eol=lf
*.js       text eol=lf
*.cjs      text eol=lf
*.json     text eol=lf
*.scss     text eol=lf
*.css      text eol=lf
*.html     text eol=lf
*.md       text eol=lf
*.mdx      text eol=lf
*.yml      text eol=lf
*.yaml     text eol=lf
*.svg      text eol=lf
*.toml     text eol=lf
*.gitignore text eol=lf

# Binary files — never normalize.
*.png      binary
*.jpg      binary
*.jpeg     binary
*.gif      binary
*.webp     binary
*.avif     binary
*.ico      binary
*.pdf      binary
*.woff     binary
*.woff2    binary
*.ttf      binary
*.otf      binary
*.mp4      binary
*.webm     binary

# Lockfile: keep LF and don't diff inline.
package-lock.json text eol=lf -diff
