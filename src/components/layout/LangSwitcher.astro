---
import Icon from '../ui/Icon.astro';
import { LOCALES, localePath, type Locale } from '../../lib/i18n';

interface Props {
  current: Locale;
}

const { current } = Astro.props;

const labels: Record<Locale, { short: string; long: string }> = {
  en: { short: 'EN', long: 'English' },
  es: { short: 'ES', long: 'Español' },
  pt: { short: 'PT', long: 'Português' },
};
---
<details class="lang">
  <summary aria-label="Change language">
    <Icon name="lucide:globe" size={14} />
    <span>{labels[current].short}</span>
    <Icon name="lucide:chevron-down" size={10} class="chev" />
  </summary>
  <div class="menu" role="menu">
    {
      LOCALES.map((l) => (
        <a
          href={localePath(l)}
          role="menuitem"
          aria-current={l === current ? 'page' : undefined}
          class:list={['item', { active: l === current }]}
        >
          <span>{labels[l].long}</span>
          <span class="code">{labels[l].short}</span>
        </a>
      ))
    }
  </div>
</details>

<style lang="scss">
@layer components {
  .lang {
    position: relative;
  }

  .lang summary {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 9px 14px;
    border: 1px solid rgb(42 33 27 / 16%);
    border-radius: 999px;
    color: var(--ink-2);
    font-size: 13px;
    list-style: none;
    cursor: pointer;
    min-height: 36px;
    user-select: none;
  }

  .lang summary::-webkit-details-marker {
    display: none;
  }

  .lang[open] .chev {
    transform: rotate(180deg);
  }

  .chev {
    transition: transform 0.2s;
  }

  .menu {
    position: absolute;
    top: calc(100% + 8px);
    right: 0;
    z-index: 10;
    min-width: 180px;
    padding: 6px;
    background: var(--cream);
    border: 1px solid rgb(42 33 27 / 10%);
    border-radius: 14px;
    box-shadow: 0 16px 48px rgb(42 33 27 / 16%);
  }

  .item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 10px 14px;
    border-radius: 8px;
    color: var(--ink-2);
    text-decoration: none;
    font-size: 14px;
    min-height: 44px;

    &:hover,
    &.active {
      background: rgb(42 33 27 / 6%);
    }

    .code {
      font-family: var(--mono);
      font-size: 11px;
      color: var(--ink-3);
    }
  }
}
</style>
