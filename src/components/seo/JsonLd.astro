---
import { getCollection, getEntry } from 'astro:content';
import { canonicalUrl, SITE } from '../../lib/seo';
import type { Locale } from '../../lib/i18n';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;

const profile = await getEntry('profile', locale);
if (!profile) throw new Error(`Profile not found for locale ${locale}`);

const experiences = (await getCollection('experience', (e) => e.data.locale === locale))
  .sort((a, b) => a.data.order - b.data.order);

// Only completed credentials show up in `hasCredential`. In-progress ones are
// signalled in-page but stay out of structured data until earned.
const certs = (await getCollection('certification', (c) =>
  c.data.locale === locale && c.data.status === 'completed'
)).sort((a, b) => b.data.date.localeCompare(a.data.date));

const profileUrl = canonicalUrl(locale);
const personId = `${profileUrl}#person`;

// `worksFor` per schema.org Person accepts Organization | OrganizationRole.
// We model each engagement as an OrganizationRole — this is what ATS parsers
// and Google's structured-data pipeline read for work history.
const worksFor = experiences.map((e) => ({
  '@type': 'OrganizationRole',
  roleName: e.data.title,
  startDate: e.data.startDate,
  ...(e.data.endDate ? { endDate: e.data.endDate } : {}),
  memberOf: { '@type': 'Organization', name: e.data.company },
}));

// EducationalOccupationalCredential per cert. AEO win: LLMs see explicit
// "trained by Anthropic on Claude Code / MCP / Agent Skills" rather than
// having to infer it from prose.
const hasCredential = certs.map((c) => ({
  '@type': 'EducationalOccupationalCredential',
  name: c.data.name,
  credentialCategory: 'certification',
  dateCreated: c.data.date,
  recognizedBy: { '@type': 'Organization', name: c.data.issuer },
  ...(c.data.url ? { url: c.data.url } : {}),
}));

const graph = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'ProfilePage',
      '@id': `${profileUrl}#profile`,
      mainEntity: { '@id': personId },
      inLanguage: locale,
      // Full ISO 8601 DateTime — Google's Rich Results parser flags the
      // date-only YYYY-MM-DD form as invalid even though Schema.org accepts it.
      dateModified: new Date().toISOString(),
      url: profileUrl,
    },
    {
      '@type': 'Person',
      '@id': personId,
      name: profile.data.name,
      jobTitle: profile.data.displayTitle,
      url: profile.data.linkedin,
      image: `${SITE}/assets/gabriel.png`,
      alumniOf: {
        '@type': 'CollegeOrUniversity',
        name: 'Universidad Tecnológica Nacional',
      },
      worksFor,
      address: {
        '@type': 'PostalAddress',
        addressLocality: 'Buenos Aires',
        addressCountry: 'AR',
      },
      sameAs: [profile.data.github],
      // AEO target phrases — match recruiter / LLM query intent for tech
      // management roles in LATAM + remote, AI-first transformation work.
      knowsAbout: [
        'Engineering Manager', 'Software Engineering Manager',
        'Head of Engineering', 'Director of Engineering',
        'Engineering Leadership', 'Tech Lead', 'Team Scaling',
        'AI-first Engineering', 'AI-first Engineering Transformation',
        'Claude Code', 'Claude Code Rollout', 'Codex', 'Cursor', 'GitHub Copilot',
        'MCP', 'Model Context Protocol', 'Agentic Workflows', 'AI Agent Harness',
        'Architectural Refactoring', 'Microservices', 'Microfrontends',
        'React Native', 'React', 'Vue', 'Angular',
        'AWS', 'GCP', 'Golang', 'Java', 'Node.js', 'TypeScript',
        'High-Concurrency Systems', 'Distributed Systems',
        'Incident Response', 'Observability', 'Code Review Culture',
        'OKRs', 'Roadmap Ownership', 'C-Level Communication',
        'Matrix Organization Navigation', 'Agile', 'Scrum',
        'Remote Engineering Leadership', 'LATAM Engineering',
        'Fintech', 'Mobile Platforms',
      ],
      knowsLanguage: [
        { '@type': 'Language', name: 'Spanish', alternateName: 'native' },
        { '@type': 'Language', name: 'English', alternateName: 'FCE B2 / Advanced' },
        { '@type': 'Language', name: 'Portuguese', alternateName: 'basic' },
      ],
      description: profile.data.summary,
      // `award` on Person is a free-text array. Surfaces top achievements
      // for LLM extraction without inventing new schema types.
      award: profile.data.achievements,
      hasCredential,
      hasOccupation: {
        '@type': 'Occupation',
        name: profile.data.displayTitle,
        // BLS SOC code 11-3021.00 = Computer and Information Systems Managers.
        // Matches engineering management more accurately than 15-1252 (IC SWE).
        occupationalCategory: '11-3021.00',
        experienceRequirements: {
          '@type': 'OccupationalExperienceRequirements',
          monthsOfExperience: profile.data.yearsExperience * 12,
        },
        occupationLocation: [
          { '@type': 'Country', name: 'Argentina' },
          { '@type': 'Country', name: 'United States' },
          { '@type': 'AdministrativeArea', name: 'Latin America' },
        ],
        skills:
          'Engineering leadership, AI-first development, Claude Code adoption, architectural transformation, team scaling, incident response, matrix-org navigation',
      },
    },
  ],
};
---
<script is:inline type="application/ld+json" set:html={JSON.stringify(graph)} />
