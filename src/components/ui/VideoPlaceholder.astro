---
interface Props {
  /** Optional real video source — when provided, renders <video> instead of placeholder. */
  src?: string;
  /** Poster image for the real video. */
  poster?: string;
  /** Accessible label; also used inside the REC chip. */
  label: string;
  /** CSS color for the secondary accent blob. */
  tint?: string;
  /** YouTube video ID for background embed (autoplay, mute, loop). */
  youtubeId?: string;
}

const { src, poster, label, tint = 'var(--accent)', youtubeId } = Astro.props;

// YouTube facade: render a lightweight placeholder + data-yt-id attribute.
// A small script (below) lazily injects the iframe via IntersectionObserver
// AFTER `astro:page-load`, so the page's LCP and TBT aren't blocked by
// YouTube's ~500KB player JS. The iframe still autoplays muted in loop.
---
{
  youtubeId ? (
    <div class="yt-wrap" data-yt-id={youtubeId} role="img" aria-label={label}>
      {/* Stylized backdrop until the iframe lands. */}
      <div class="mesh" />
      <div class="blob a" />
      <div class="blob b" style={`background: ${tint};`} />
      <div class="blob c" />
      <div class="rec">
        <span class="rec-dot" />
        <span>{label}</span>
      </div>
    </div>
  ) : src ? (
    <video
      autoplay
      loop
      muted
      playsinline
      preload="metadata"
      poster={poster}
      aria-label={label}
      class="video"
    >
      <source src={src} type="video/mp4" />
    </video>
  ) : (
    <div class="placeholder" role="img" aria-label={label}>
      <div class="mesh" />
      <div class="blob a" />
      <div class="blob b" style={`background: ${tint};`} />
      <div class="blob c" />
      <div class="blocks" />
      <div class="scan" />
      <div class="grain" />
      <div class="rec">
        <span class="rec-dot" />
        <span>REC · {label}</span>
      </div>
    </div>
  )
}

<script>
  // Facade loader: replace YouTube placeholders with real iframes once the
  // viewer is near and the page has settled. Runs on every astro:page-load.
  function loadYtFacades(): void {
    const wraps = document.querySelectorAll<HTMLElement>('.yt-wrap[data-yt-id]');
    if (wraps.length === 0) return;

    const inject = (wrap: HTMLElement): void => {
      const id = wrap.dataset.ytId;
      if (!id || wrap.dataset.loaded === '1') return;
      wrap.dataset.loaded = '1';
      const iframe = document.createElement('iframe');
      iframe.className = 'yt';
      iframe.src =
        `https://www.youtube-nocookie.com/embed/${id}` +
        `?autoplay=1&mute=1&loop=1&playlist=${id}&controls=0&showinfo=0` +
        `&modestbranding=1&playsinline=1&rel=0&iv_load_policy=3&disablekb=1&fs=0`;
      iframe.title = wrap.getAttribute('aria-label') ?? 'background video';
      iframe.allow = 'autoplay; encrypted-media; picture-in-picture';
      iframe.referrerPolicy = 'strict-origin-when-cross-origin';
      // Inline styles (Astro scoped CSS doesn't reach runtime-injected nodes).
      // 177.78% width with 200% height + scale crops YouTube chrome around edges.
      Object.assign(iframe.style, {
        position: 'absolute',
        top: '50%',
        left: '50%',
        width: '177.78%',
        height: '200%',
        transform: 'translate(-50%, -50%) scale(1.15)',
        border: '0',
        pointerEvents: 'none',
      });
      wrap.appendChild(iframe);
    };

    const io = new IntersectionObserver(
      (entries) => {
        for (const e of entries) {
          if (e.isIntersecting) {
            inject(e.target as HTMLElement);
            io.unobserve(e.target);
          }
        }
      },
      { rootMargin: '200px' },
    );
    wraps.forEach((w) => io.observe(w));
  }

  // Defer until idle to avoid LCP/TBT pressure.
  function schedule(): void {
    if ('requestIdleCallback' in window) {
      (window as Window & { requestIdleCallback: (cb: () => void) => void }).requestIdleCallback(loadYtFacades);
    } else {
      setTimeout(loadYtFacades, 1500);
    }
  }

  schedule();
  document.addEventListener('astro:page-load', schedule);
</script>

<style lang="scss">
@layer components {
  .video,
  .placeholder,
  .yt-wrap {
    /* Local color token for the recording chip dot. */
    --rec-color: #e3624b;
    position: relative;
    width: 100%;
    height: 100%;
    overflow: hidden;
    background: var(--ink);
    color: var(--cream);
  }

  .video {
    object-fit: cover;
  }

  // YouTube iframe: scale to cover container, crop edges to hide chrome,
  // disable pointer events so it behaves like a background.
  .yt {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 177.78%; /* 16:9 width when scaled vertically */
    height: 200%; /* extends beyond container to crop UI/chrome */
    transform: translate(-50%, -50%) scale(1.15);
    border: 0;
    pointer-events: none;
  }

  .mesh {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(at 30% 40%, var(--ink-2), transparent 60%),
      radial-gradient(at 70% 60%, var(--accent-light), transparent 65%);
    animation: mesh-drift 18s ease-in-out infinite alternate;
  }

  @keyframes mesh-drift {
    0%   { filter: hue-rotate(0deg) saturate(0.9) brightness(0.95); transform: scale(1.02); }
    100% { filter: hue-rotate(-12deg) saturate(1) brightness(1); transform: scale(1.06); }
  }

  .blob {
    position: absolute;
    width: 60%;
    aspect-ratio: 1;
    border-radius: 50%;
    filter: blur(40px);
    mix-blend-mode: screen;
    background: var(--accent-light);
  }

  .blob.a {
    top: -10%;
    left: -10%;
    animation: blob-a 22s ease-in-out infinite alternate;
  }

  .blob.b {
    right: -10%;
    bottom: -20%;
    animation: blob-b 26s ease-in-out infinite alternate;
  }

  .blob.c {
    top: 20%;
    right: 20%;
    width: 40%;
    animation: blob-c 20s ease-in-out infinite alternate;
  }

  @keyframes blob-a {
    0%   { transform: translate(0, 0); }
    100% { transform: translate(15%, 10%); }
  }

  @keyframes blob-b {
    0%   { transform: translate(0, 0); }
    100% { transform: translate(-15%, -10%); }
  }

  @keyframes blob-c {
    0%   { transform: translate(0, 0); }
    100% { transform: translate(-10%, 12%); }
  }

  .blocks {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(to right, rgb(255 255 255 / 4%) 1px, transparent 1px),
      linear-gradient(to bottom, rgb(255 255 255 / 4%) 1px, transparent 1px);
    background-size: 60px 60px;
    mix-blend-mode: overlay;
    animation: blocks-shift 12s linear infinite;
  }

  @keyframes blocks-shift {
    0%   { transform: translate(0, 0); }
    100% { transform: translate(60px, 60px); }
  }

  .scan {
    position: absolute;
    top: -60%;
    left: 0;
    right: 0;
    height: 60%;
    background: linear-gradient(180deg, transparent 0%, rgb(255 255 255 / 4%) 50%, transparent 100%);
    animation: scan 8s linear infinite;
    pointer-events: none;
    mix-blend-mode: overlay;
  }

  @keyframes scan {
    0%   { transform: translateY(0); }
    100% { transform: translateY(280%); }
  }

  .grain {
    position: absolute;
    inset: 0;
    opacity: 0.18;
    pointer-events: none;
    mix-blend-mode: overlay;
    /* stylelint-disable-next-line function-url-quotes */
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.92' numOctaves='3' /%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.6'/%3E%3C/svg%3E");
    background-size: 220px 220px;
  }

  .rec {
    position: absolute;
    top: 16px;
    left: 16px;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 6px 12px;
    background: rgb(0 0 0 / 45%);
    border-radius: 999px;
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--cream);
  }

  .rec-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--rec-color);
    animation: rec-blink 1.4s ease-in-out infinite;
  }

  @keyframes rec-blink {
    0%, 100% { opacity: 1; }
    50%      { opacity: 0.25; }
  }
}
</style>
