---
interface Props {
  /** CSS color for the pulse. Default matches the page accent green. */
  color?: string;
}

const { color = '#5b9a6e' } = Astro.props;
---
<span class="pulse-dot" style={`--dot-color: ${color};`} aria-hidden="true">
  <span class="ring"></span>
</span>

<style lang="scss">
@layer components {
  // Use composited transform + opacity for GPU-accelerated pulse.
  // (box-shadow animation triggers paint and fails Lighthouse's
  // "Avoid non-composited animations" diagnostic.)
  .pulse-dot {
    position: relative;
    display: inline-block;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--dot-color);
  }

  .ring {
    position: absolute;
    inset: 0;
    border-radius: 50%;
    background: var(--dot-color);
    transform-origin: center;
    will-change: transform, opacity;
    animation: pulse 2s ease-out infinite;
  }

  @keyframes pulse {
    0% {
      transform: scale(1);
      opacity: 0.5;
    }

    70% {
      transform: scale(3);
      opacity: 0;
    }

    100% {
      transform: scale(3);
      opacity: 0;
    }
  }
}
</style>
