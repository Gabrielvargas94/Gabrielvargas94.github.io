---
import Icon from './Icon.astro';

interface Props {
  href: string;
  label: string;
  variant?: 'primary' | 'ghost' | 'invert';
  /** Lucide-prefixed icon name, e.g. "lucide:linkedin". */
  icon?: string;
  /** Open in a new tab with rel="noopener noreferrer". Defaults true. */
  external?: boolean;
}

const { href, label, variant = 'primary', icon, external = true } = Astro.props;
---
<a
  href={href}
  class:list={['cta', `cta-${variant}`]}
  {...(external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
>
  {icon && <Icon name={icon} size={16} />}
  <span>{label}</span>
</a>

<style lang="scss">
@layer components {
  .cta {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 12px 22px;
    border-radius: 999px;
    text-decoration: none;
    font-size: 14px;
    font-weight: 500;
    letter-spacing: -0.005em;
    min-height: 44px;
    transition: transform 0.2s, box-shadow 0.2s, background 0.2s;
  }

  .cta-primary {
    background: var(--ink);
    color: var(--cream);

    &:hover {
      transform: translateY(-1px);
      box-shadow: 0 6px 16px rgb(42 33 27 / 18%);
    }
  }

  .cta-ghost {
    background: transparent;
    color: var(--ink);
    border: 1px solid rgb(42 33 27 / 16%);

    &:hover {
      background: rgb(42 33 27 / 5%);
    }
  }

  .cta-invert {
    background: var(--cream);
    color: var(--ink);

    &:hover {
      transform: translateY(-1px);
      box-shadow: 0 6px 16px rgb(0 0 0 / 25%);
    }
  }
}
</style>
