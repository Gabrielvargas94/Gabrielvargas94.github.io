---
import Pill from '../ui/Pill.astro';
import Icon from '../ui/Icon.astro';
import type { Locale } from '../../lib/i18n';
import uiEn from '../../content/ui/en.json';
import uiEs from '../../content/ui/es.json';
import uiPt from '../../content/ui/pt.json';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const uiByLocale = { en: uiEn, es: uiEs, pt: uiPt } as const;
const ui = uiByLocale[locale];
const s = ui.sections.dnd;
const sessionLabel: Record<Locale, string> = {
  en: 'Table · Session 47',
  es: 'Mesa · Sesión 47',
  pt: 'Mesa · Sessão 47',
};
const initiativeLabel: Record<Locale, string> = {
  en: 'roll · for · initiative',
  es: 'tirá · iniciativa',
  pt: 'role · pela · iniciativa',
};
const rollAriaLabel: Record<Locale, string> = {
  en: 'Roll the d20 for initiative',
  es: 'Tirar el d20 por iniciativa',
  pt: 'Rolar o d20 pela iniciativa',
};
---
<section id="dnd" aria-labelledby="dnd-title">
  <div class="inner">
    <div
      class="visual"
      role="button"
      tabindex="0"
      aria-label={rollAriaLabel[locale]}
    >
      <span class="meta-top">
        <span class="rec-dot" aria-hidden="true"></span>
        {sessionLabel[locale]}
      </span>
      {/*
        True 3D icosahedron in pure CSS. 20 triangular faces split into 4
        groups: top cap (5), antiprism up-pointing band (5), antiprism
        down-pointing band (5), bottom cap (5). Each face is a div clipped
        to an equilateral triangle and rotated to its place on the polyhedron
        via rotateY (azimuth) → rotateX (tilt) → translateZ (push out by
        inradius). Container has perspective so the rotation reads 3D.
      */}
      {/*
        20-face icosahedron — pure CSS 3D approach adapted from
        vicentemundim's CodePen "3d d20 die with pure CSS" (nXNvBw).
        Each face is a CSS border-triangle (border-left/right transparent +
        border-bottom colored = upward-pointing triangle of zero-width 0-height
        div). Numbers come from `counter-increment: steps` + `::before` so the
        same 20 figures auto-number 1..20 without per-face content.
      */}
      <div class="die" data-face="20" aria-hidden="true">
        {Array.from({ length: 20 }, (_, i) => (
          <figure class={`face face-${i + 1}`} />
        ))}
      </div>
      <span class="meta-bot">{initiativeLabel[locale]}</span>
    </div>

    <script>
      // Roll-to-face flow: click/tap/Enter on the frame adds .rolling for 3s
      // (the multi-step roll keyframe animation plays) then drops .rolling and
      // sets `data-face` to a fresh random number 1..20, which the CSS targets
      // to land the die on that face via a 0.5s ease-out transition.
      const ROLL_MS = 3000;

      function attachRollHandler(): void {
        const visuals = document.querySelectorAll<HTMLElement>('#dnd .visual');
        visuals.forEach((visual) => {
          if (visual.dataset.rollWired === '1') return;
          visual.dataset.rollWired = '1';
          const die = visual.querySelector<HTMLElement>('.die');
          if (!die) return;

          let timeoutId: number | undefined;
          let lastFace = 1;
          const rand = (): number => {
            let f = Math.floor(Math.random() * 20) + 1;
            if (f === lastFace) f = rand();
            lastFace = f;
            return f;
          };

          const roll = (): void => {
            die.removeAttribute('data-face');
            // Force reflow before re-adding the class so the animation restarts
            // even if .rolling was already present.
            die.classList.remove('rolling');
            void die.offsetHeight;
            die.classList.add('rolling');
            if (timeoutId !== undefined) window.clearTimeout(timeoutId);
            timeoutId = window.setTimeout(() => {
              die.classList.remove('rolling');
              die.dataset.face = String(rand());
            }, ROLL_MS);
          };

          visual.addEventListener('click', roll);
          visual.addEventListener('keydown', (e: KeyboardEvent) => {
            if (e.key === 'Enter' || e.key === ' ') {
              e.preventDefault();
              roll();
            }
          });
        });
      }

      attachRollHandler();
      document.addEventListener('astro:page-load', attachRollHandler);
    </script>

    <div class="copy">
      <Pill>
        <span class="dice" aria-hidden="true"><Icon name="lucide:dice-6" size={14} /></span>
        {s.kicker}
      </Pill>
      <h3 id="dnd-title">{s.title}</h3>
      <p>{s.body}</p>

      <ul class="pulls">
        {s.pulls.map((p) => (
          <li>
            <span class="k">{p.k}</span>
            <span class="v">{p.v}</span>
          </li>
        ))}
      </ul>
    </div>
  </div>
</section>

<style lang="scss">
@layer components {
  section {
    background: var(--paper);
    padding: clamp(64px, 8vw, 120px) clamp(16px, 4vw, 64px);
  }

  .inner {
    max-width: 1280px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(40px, 6vw, 96px);
    align-items: center;
  }

  // Framed d20 with film-still aesthetic — also a button: click/tap/Enter rolls.
  .visual {
    position: relative;
    aspect-ratio: 1 / 1;
    max-width: 520px;
    width: 100%;
    margin: 0 auto;
    display: grid;
    place-items: center;
    overflow: hidden;
    border-radius: 20px;
    background: linear-gradient(135deg, #2a211b 0%, #4a3326 60%, #6b4a35 100%);
    box-shadow: 0 24px 60px rgb(42 33 27 / 25%);
    perspective: 800px;
    cursor: pointer;
    user-select: none;

    &:hover {
      box-shadow: 0 24px 60px rgb(42 33 27 / 35%), 0 0 0 1px rgb(227 167 107 / 25%);
    }

    &:focus-visible {
      outline: 2px solid var(--accent-light, #e3a76b);
      outline-offset: 4px;
    }
  }

  // d20 geometry — values mirror vicentemundim's CodePen so the well-tested
  // angle/translate set is preserved. The only swap is colour: CodePen's
  // bright green replaced by the site's accent gradient.
  $container-w: 220px;
  $face-w: $container-w * 0.5;
  $face-h: $face-w * 0.86;
  $angle: 53deg;
  $ring-angle: -11deg;
  $side-angle: 72deg;
  $rotate-x: -$angle;
  $translate-z: $face-w * 0.335;
  $translate-y: -$face-h * 0.15;
  $translate-ring-z: $face-w * 0.75;
  $translate-ring-y: $face-h * 0.78 + $translate-y;
  $translate-lower-z: $translate-z;
  $translate-lower-y: $face-h * 0.78 + $translate-ring-y;

  .die {
    position: relative;
    width: $container-w;
    height: $container-w;
    transform-style: preserve-3d;
    transition: transform 0.5s ease-out;
    // Initial pose lands on face 20 (set via data-face attribute below).
    counter-reset: steps;

    &.rolling {
      animation: roll-d20 3s linear;
    }

    // Top cap (faces 1–5): tilted up about the top vertex.
    @for $i from 1 through 5 {
      &[data-face="#{$i}"] {
        $am: $i - 1;
        transform: rotateX(-$angle) rotateY($side-angle * $am);
      }
    }

    // Bottom cap (faces 16–20): flipped 180° from top cap.
    @for $i from 16 through 20 {
      &[data-face="#{$i}"] {
        $am: $i - 15;
        transform: rotateX(-$angle + 180deg) rotateY(-$side-angle * $am);
      }
    }

    // Upper anti-prism ring (faces 6–10): inverted triangles, slight tilt.
    @for $i from 6 through 10 {
      &[data-face="#{$i}"] {
        $am: $i - 6;
        transform: rotateX(-$ring-angle) rotateZ(180deg) rotateY($side-angle * $am);
      }
    }

    // Lower anti-prism ring (faces 11–15): upright triangles, slight tilt,
    // offset by half a side-angle so they fit between the upper-ring faces.
    @for $i from 11 through 15 {
      &[data-face="#{$i}"] {
        $am: $i - 8;
        transform: rotateX(-$ring-angle) rotateY(-$side-angle * $am - $side-angle * 0.5);
      }
    }
  }

  // Each face is a rectangle clipped to an equilateral-ish triangle so we
  // can use a full linear-gradient background (the CodePen used solid borders
  // which can't gradient). transform-origin pinned to the apex (50% 0%)
  // preserves the CodePen's pivot geometry, so all the @for transforms below
  // — copied verbatim — still place the triangles correctly.
  .face {
    $h-margin: -$face-w * 0.5;

    position: absolute;
    left: 50%;
    top: 0;
    margin: 0 $h-margin;
    width: $face-w;
    height: $face-h;
    clip-path: polygon(50% 0%, 100% 100%, 0% 100%);
    background: linear-gradient(155deg, #e3a76b 0%, #b3743c 55%, #7a3d1c 100%);
    transform-style: preserve-3d;
    transform-origin: 50% 0%;
    backface-visibility: hidden;
    counter-increment: steps 1;
    // Subtle inner highlight along the apex edge — reads as a beveled corner.
    box-shadow:
      inset 0 1px 0 rgb(255 248 230 / 22%),
      inset 0 -8px 14px rgb(0 0 0 / 18%);

    &::before {
      content: counter(steps);
      position: absolute;
      inset: 0;
      display: grid;
      place-items: center;
      // Triangle centroid is 1/3 from base (≈y=57 for h=86); offset text
      // toward the centroid so it sits on the visual centre of mass.
      padding-top: $face-h * 0.3;
      color: var(--cream);
      text-shadow: 0 1px 2px rgb(0 0 0 / 65%), 0 0 12px rgb(122 61 28 / 35%);
      font-family: var(--mono);
      font-size: $face-h * 0.4;
      font-weight: 700;
      letter-spacing: 0.02em;
    }

    // Top cap face transforms (faces 1–5).
    @for $i from 1 through 5 {
      &:nth-child(#{$i}) {
        $am: $i - 1;
        transform:
          rotateY(-$side-angle * $am)
          translateZ($translate-z)
          translateY($translate-y)
          rotateX($angle);
      }
    }

    // Bottom cap face transforms (faces 16–20).
    @for $i from 16 through 20 {
      &:nth-child(#{$i}) {
        $am: $i - 18;
        transform:
          rotateY($side-angle * $am + $side-angle * 0.5)
          translateZ($translate-lower-z)
          translateY($translate-lower-y)
          rotateZ(180deg)
          rotateX($angle);
      }
    }

    // Upper ring (faces 6–10): inverted triangles.
    @for $i from 6 through 10 {
      &:nth-child(#{$i}) {
        $am: $i - 11;
        transform:
          rotateY(-$side-angle * $am)
          translateZ($translate-ring-z)
          translateY($translate-ring-y)
          rotateZ(180deg)
          rotateX($ring-angle);
      }
    }

    // Lower ring (faces 11–15): upright triangles offset by half a side-angle.
    @for $i from 11 through 15 {
      &:nth-child(#{$i}) {
        $am: $i - 8;
        transform:
          rotateY($side-angle * $am + $side-angle * 0.5)
          translateZ($translate-ring-z)
          translateY($translate-ring-y)
          rotateX($ring-angle);
      }
    }
  }

  // Tumble-and-translate roll keyframes (mirrors the CodePen sequence so the
  // motion arc reads as a real die bounce instead of a clean spin).
  @keyframes roll-d20 {
    10% { transform: rotateX(0deg)   rotateY(0deg)   rotateZ(0deg); }
    30% { transform: rotateX(120deg) rotateY(240deg) rotateZ(0deg) translateX(40px) translateY(40px); }
    50% { transform: rotateX(240deg) rotateY(480deg) rotateZ(0deg) translateX(-40px) translateY(-40px); }
    70% { transform: rotateX(360deg) rotateY(720deg) rotateZ(0deg); }
    90% { transform: rotateX(480deg) rotateY(960deg) rotateZ(0deg); }
  }

  @media (prefers-reduced-motion: reduce) {
    .die {
      transition: none;
      &.rolling { animation: none; }
    }
  }

  .meta-top,
  .meta-bot {
    position: absolute;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: rgb(247 242 232 / 60%);
  }

  .meta-top { top: 18px; left: 22px; }
  .meta-bot { right: 22px; bottom: 18px; letter-spacing: 0.12em; color: rgb(247 242 232 / 50%); }

  .rec-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: #e3624b;
    animation: rec-blink 1.4s ease-in-out infinite;
  }

  @keyframes rec-blink {
    0%, 100% { opacity: 1; }
    50%      { opacity: 0.25; }
  }

  // Copy column.
  .copy {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .dice {
    display: inline-flex;
    margin-right: 2px;
  }

  h3 {
    margin: 0;
    font-family: var(--serif);
    font-size: clamp(32px, 4.2vw, 56px);
    line-height: 1.05;
    letter-spacing: -0.025em;
    font-weight: 400;
    color: var(--ink);
    text-wrap: balance;
  }

  .copy p {
    margin: 0;
    max-width: 520px;
    font-size: 18px;
    line-height: 1.55;
    color: var(--ink-2);
    text-wrap: pretty;
  }

  .pulls {
    list-style: none;
    margin: 16px 0 0;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 16px;
  }

  .pulls li {
    display: flex;
    flex-direction: column;
    gap: 10px;
    padding: 18px 16px;
    border-top: 1px solid var(--ink);
  }

  .k {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--accent-dark);
  }

  .v {
    font-family: var(--serif);
    font-size: 17px;
    line-height: 1.35;
    color: var(--ink);
  }

  @media (width <= 880px) {
    .inner {
      grid-template-columns: 1fr;
    }

    .pulls {
      grid-template-columns: 1fr;
    }
  }
}
</style>
