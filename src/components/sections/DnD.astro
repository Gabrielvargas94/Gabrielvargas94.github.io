---
import Pill from '../ui/Pill.astro';
import Icon from '../ui/Icon.astro';
import type { Locale } from '../../lib/i18n';
import uiEn from '../../content/ui/en.json';
import uiEs from '../../content/ui/es.json';
import uiPt from '../../content/ui/pt.json';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const uiByLocale = { en: uiEn, es: uiEs, pt: uiPt } as const;
const ui = uiByLocale[locale];
const s = ui.sections.dnd;
const sessionLabel: Record<Locale, string> = {
  en: 'Table · Session 47',
  es: 'Mesa · Sesión 47',
  pt: 'Mesa · Sessão 47',
};
const initiativeLabel: Record<Locale, string> = {
  en: 'roll · for · initiative',
  es: 'tirá · iniciativa',
  pt: 'role · pela · iniciativa',
};
const rollAriaLabel: Record<Locale, string> = {
  en: 'Roll the d20 for initiative',
  es: 'Tirar el d20 por iniciativa',
  pt: 'Rolar o d20 pela iniciativa',
};
---
<section id="dnd" aria-labelledby="dnd-title">
  <div class="inner">
    <div
      class="visual"
      role="button"
      tabindex="0"
      aria-label={rollAriaLabel[locale]}
    >
      <span class="meta-top">
        <span class="rec-dot" aria-hidden="true"></span>
        {sessionLabel[locale]}
      </span>
      {/*
        True 3D icosahedron in pure CSS. 20 triangular faces split into 4
        groups: top cap (5), antiprism up-pointing band (5), antiprism
        down-pointing band (5), bottom cap (5). Each face is a div clipped
        to an equilateral triangle and rotated to its place on the polyhedron
        via rotateY (azimuth) → rotateX (tilt) → translateZ (push out by
        inradius). Container has perspective so the rotation reads 3D.
      */}
      <div class="die" aria-hidden="true">
        <div class="face">20</div>
        <div class="face">8</div>
        <div class="face">14</div>
        <div class="face">2</div>
        <div class="face">17</div>

        <div class="face down">13</div>
        <div class="face down">7</div>
        <div class="face down">16</div>
        <div class="face down">5</div>
        <div class="face down">19</div>

        <div class="face">1</div>
        <div class="face">11</div>
        <div class="face">4</div>
        <div class="face">18</div>
        <div class="face">6</div>

        <div class="face down">9</div>
        <div class="face down">10</div>
        <div class="face down">3</div>
        <div class="face down">15</div>
        <div class="face down">12</div>
      </div>
      <span class="meta-bot">{initiativeLabel[locale]}</span>
    </div>

    <script>
      // Click/tap/keyboard on the frame triggers a one-shot roll: the idle
      // rotation animation gets disabled and the die transitions to a fresh
      // random orientation. Each subsequent click re-rolls.
      function attachRollHandler(): void {
        const visuals = document.querySelectorAll<HTMLElement>('#dnd .visual');
        visuals.forEach((visual) => {
          if (visual.dataset.rollWired === '1') return;
          visual.dataset.rollWired = '1';
          const die = visual.querySelector<HTMLElement>('.die');
          if (!die) return;
          const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

          const roll = (): void => {
            // Lots of full spins + random landing pose so each roll feels chaotic.
            const rx = 720 + Math.random() * 720;
            const ry = 720 + Math.random() * 720;
            const rz = Math.random() * 360;
            die.style.animation = 'none';
            // Reflow to lock the animation: none state in.
            void die.offsetHeight;
            die.style.transition = prefersReduced
              ? 'none'
              : 'transform 1.6s cubic-bezier(0.16, 1, 0.3, 1)';
            die.style.transform = `rotateX(${rx}deg) rotateY(${ry}deg) rotateZ(${rz}deg)`;
          };

          visual.addEventListener('click', roll);
          visual.addEventListener('keydown', (e: KeyboardEvent) => {
            if (e.key === 'Enter' || e.key === ' ') {
              e.preventDefault();
              roll();
            }
          });
        });
      }

      attachRollHandler();
      document.addEventListener('astro:page-load', attachRollHandler);
    </script>

    <div class="copy">
      <Pill>
        <span class="dice" aria-hidden="true"><Icon name="lucide:dice-6" size={14} /></span>
        {s.kicker}
      </Pill>
      <h3 id="dnd-title">{s.title}</h3>
      <p>{s.body}</p>

      <ul class="pulls">
        {s.pulls.map((p) => (
          <li>
            <span class="k">{p.k}</span>
            <span class="v">{p.v}</span>
          </li>
        ))}
      </ul>
    </div>
  </div>
</section>

<style lang="scss">
@layer components {
  section {
    background: var(--paper);
    padding: clamp(64px, 8vw, 120px) clamp(16px, 4vw, 64px);
  }

  .inner {
    max-width: 1280px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(40px, 6vw, 96px);
    align-items: center;
  }

  // Framed d20 with film-still aesthetic — also a button: click/tap/Enter rolls.
  .visual {
    position: relative;
    aspect-ratio: 1 / 1;
    max-width: 520px;
    width: 100%;
    margin: 0 auto;
    display: grid;
    place-items: center;
    overflow: hidden;
    border-radius: 20px;
    background: linear-gradient(135deg, #2a211b 0%, #4a3326 60%, #6b4a35 100%);
    box-shadow: 0 24px 60px rgb(42 33 27 / 25%);
    perspective: 800px;
    cursor: pointer;
    user-select: none;

    &:hover {
      box-shadow: 0 24px 60px rgb(42 33 27 / 35%), 0 0 0 1px rgb(227 167 107 / 25%);
    }

    &:focus-visible {
      outline: 2px solid var(--accent-light, #e3a76b);
      outline-offset: 4px;
    }
  }

  // Icosahedron geometry constants:
  //   --E: edge length in px (≈ container ÷ 1.902)
  //   --R: inradius (face-to-center distance) ≈ edge × 0.7558
  // For the rendered ~280px effective container, edge ~150 + inradius ~113.
  .die {
    --E: 150px;
    --R: 113px;
    width: var(--E);
    height: var(--E);
    position: relative;
    transform-style: preserve-3d;
    animation: roll-d20 18s linear infinite;
  }

  .face {
    position: absolute;
    inset: 0;
    display: grid;
    place-items: center;
    padding-top: 12%;
    // Equilateral triangle inscribed in the square face div, apex up
    // (height/width = √3/2 = 0.866 → 6.7% margins top/bottom).
    clip-path: polygon(50% 6.7%, 100% 93.3%, 0% 93.3%);
    background: linear-gradient(155deg, #e3a76b 0%, #b3743c 55%, #7a3d1c 100%);
    color: var(--cream);
    font-family: var(--mono);
    font-size: 22px;
    font-weight: 600;
    letter-spacing: 0.02em;
    backface-visibility: hidden;
    box-shadow: inset 0 0 0 1px rgb(0 0 0 / 22%);
  }

  // Inverted equilateral for down-pointing faces (antiprism band + bottom cap).
  .face.down {
    clip-path: polygon(50% 93.3%, 100% 6.7%, 0% 6.7%);
    padding-top: 0;
    padding-bottom: 12%;
    align-items: end;
  }

  // 4 groups of 5 faces. Tilt angles derive from the icosahedron's face
  // colatitudes (37.38°, 79.19°, 100.81°, 142.62° from north pole).
  @for $i from 0 through 4 {
    // Top cap — 5 faces around the top vertex, azimuths 36° + 72°·i.
    .face:nth-child(#{$i + 1}) {
      transform:
        rotateY(#{36deg + 72deg * $i})
        rotateX(-52.62deg)
        translateZ(var(--R));
    }
    // Antiprism down-pointing band — azimuths 0° + 72°·i.
    .face:nth-child(#{$i + 6}) {
      transform:
        rotateY(#{72deg * $i})
        rotateX(10.81deg)
        translateZ(var(--R));
    }
    // Antiprism up-pointing band — azimuths 36° + 72°·i.
    .face:nth-child(#{$i + 11}) {
      transform:
        rotateY(#{36deg + 72deg * $i})
        rotateX(-10.81deg)
        translateZ(var(--R));
    }
    // Bottom cap — 5 faces around the bottom vertex, azimuths 0° + 72°·i.
    .face:nth-child(#{$i + 16}) {
      transform:
        rotateY(#{72deg * $i})
        rotateX(52.62deg)
        translateZ(var(--R));
    }
  }

  @keyframes roll-d20 {
    0%   { transform: rotateX(-10deg) rotateY(0deg)   rotateZ(0deg); }
    50%  { transform: rotateX(190deg) rotateY(180deg) rotateZ(20deg); }
    100% { transform: rotateX(350deg) rotateY(360deg) rotateZ(0deg); }
  }

  @media (prefers-reduced-motion: reduce) {
    .die { animation: none; transform: rotateX(-12deg) rotateY(28deg); }
  }

  .meta-top,
  .meta-bot {
    position: absolute;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: rgb(247 242 232 / 60%);
  }

  .meta-top { top: 18px; left: 22px; }
  .meta-bot { right: 22px; bottom: 18px; letter-spacing: 0.12em; color: rgb(247 242 232 / 50%); }

  .rec-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: #e3624b;
    animation: rec-blink 1.4s ease-in-out infinite;
  }

  @keyframes rec-blink {
    0%, 100% { opacity: 1; }
    50%      { opacity: 0.25; }
  }

  // Copy column.
  .copy {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .dice {
    display: inline-flex;
    margin-right: 2px;
  }

  h3 {
    margin: 0;
    font-family: var(--serif);
    font-size: clamp(32px, 4.2vw, 56px);
    line-height: 1.05;
    letter-spacing: -0.025em;
    font-weight: 400;
    color: var(--ink);
    text-wrap: balance;
  }

  .copy p {
    margin: 0;
    max-width: 520px;
    font-size: 18px;
    line-height: 1.55;
    color: var(--ink-2);
    text-wrap: pretty;
  }

  .pulls {
    list-style: none;
    margin: 16px 0 0;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 16px;
  }

  .pulls li {
    display: flex;
    flex-direction: column;
    gap: 10px;
    padding: 18px 16px;
    border-top: 1px solid var(--ink);
  }

  .k {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--accent-dark);
  }

  .v {
    font-family: var(--serif);
    font-size: 17px;
    line-height: 1.35;
    color: var(--ink);
  }

  @media (width <= 880px) {
    .inner {
      grid-template-columns: 1fr;
    }

    .pulls {
      grid-template-columns: 1fr;
    }
  }
}
</style>
