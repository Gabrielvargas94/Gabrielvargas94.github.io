---
import Pill from '../ui/Pill.astro';
import Icon from '../ui/Icon.astro';
import type { Locale } from '../../lib/i18n';
import uiEn from '../../content/ui/en.json';
import uiEs from '../../content/ui/es.json';
import uiPt from '../../content/ui/pt.json';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const uiByLocale = { en: uiEn, es: uiEs, pt: uiPt } as const;
const ui = uiByLocale[locale];
const s = ui.sections.aiIntro;
---
<section id="ai-intro" aria-labelledby="ai-intro-title">
  <div class="inner">
    <div class="head">
      <Pill variant="dark">{s.kicker}</Pill>
      <h2 id="ai-intro-title">{s.title}</h2>
      <p>{s.desc}</p>
    </div>
    <aside class="badge" aria-hidden="true">
      <Icon name="lucide:sparkles" size={26} />
      <span>Claude · Cursor · MCP</span>
    </aside>
  </div>
</section>

<style lang="scss">
@layer components {
  section {
    background: var(--ink);
    color: var(--cream);
    padding: clamp(80px, 10vw, 140px) clamp(16px, 4vw, 64px);
  }

  .inner {
    max-width: 1320px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 40px;
    align-items: end;
  }

  .head {
    display: flex;
    flex-direction: column;
    gap: 20px;
    max-width: 920px;
  }

  h2 {
    margin: 0;
    font-family: var(--serif);
    font-size: clamp(36px, 5.4vw, 72px);
    line-height: 1;
    letter-spacing: -0.025em;
    font-weight: 400;
    color: var(--cream);
    text-wrap: balance;
  }

  .head p {
    margin: 0;
    max-width: 720px;
    font-size: clamp(16px, 1.2vw, 19px);
    line-height: 1.6;
    color: rgb(247 242 232 / 75%);
    text-wrap: pretty;
  }

  .badge {
    display: inline-flex;
    align-items: center;
    gap: 14px;
    color: var(--accent-light);
    font-family: var(--mono);
    font-size: 12px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  @media (width <= 880px) {
    .inner {
      grid-template-columns: 1fr;
      align-items: start;
    }
  }
}
</style>
