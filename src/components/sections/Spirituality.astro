---
import Pill from '../ui/Pill.astro';
import Icon from '../ui/Icon.astro';
import type { Locale } from '../../lib/i18n';
import uiEn from '../../content/ui/en.json';
import uiEs from '../../content/ui/es.json';
import uiPt from '../../content/ui/pt.json';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const uiByLocale = { en: uiEn, es: uiEs, pt: uiPt } as const;
const ui = uiByLocale[locale];
const s = ui.sections.spirit;
---
<section id="spirit" aria-labelledby="spirit-title">
  <div class="inner">
    <div class="copy">
      <Pill>
        <span class="lotus" aria-hidden="true"><Icon name="lucide:sun" size={14} /></span>
        {s.kicker}
      </Pill>
      <h3 id="spirit-title">{s.title}</h3>
      <p>{s.body}</p>
    </div>

    <figure class="quote-frame">
      <svg
        class="rings"
        viewBox="0 0 400 400"
        aria-hidden="true"
        focusable="false"
      >
        <g fill="none" stroke="var(--ink)" stroke-width="0.7">
          <circle cx="200" cy="200" r="40" />
          <circle cx="200" cy="200" r="80" />
          <circle cx="200" cy="200" r="120" />
          <circle cx="200" cy="200" r="160" />
          <circle cx="200" cy="200" r="200" />
          <circle cx="200" cy="200" r="240" />
        </g>
      </svg>
      <blockquote>“{s.pull}”</blockquote>
    </figure>
  </div>
</section>

<style lang="scss">
@layer components {
  section {
    background: var(--cream);
    padding: clamp(64px, 8vw, 120px) clamp(16px, 4vw, 64px);
  }

  .inner {
    max-width: 1280px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 0.9fr 1.1fr;
    gap: clamp(40px, 6vw, 96px);
    align-items: center;
  }

  .copy {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .lotus {
    display: inline-flex;
    margin-right: 2px;
  }

  h3 {
    margin: 0;
    font-family: var(--serif);
    font-size: clamp(32px, 4.2vw, 56px);
    line-height: 1.05;
    letter-spacing: -0.025em;
    font-weight: 400;
    color: var(--ink);
    text-wrap: balance;
  }

  .copy p {
    margin: 0;
    max-width: 520px;
    font-size: 18px;
    line-height: 1.6;
    color: var(--ink-2);
    text-wrap: pretty;
  }

  .quote-frame {
    position: relative;
    margin: 0;
    padding: clamp(40px, 5vw, 72px);
    background: var(--cream-2);
    border: 1px solid rgb(42 33 27 / 10%);
    border-radius: 20px;
    text-align: center;
    overflow: clip;
  }

  .rings {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    opacity: 0.16;
    pointer-events: none;
  }

  blockquote {
    position: relative;
    margin: 0;
    font-family: var(--serif);
    font-size: clamp(24px, 2.5vw, 36px);
    line-height: 1.3;
    letter-spacing: -0.015em;
    font-weight: 400;
    font-style: italic;
    color: var(--ink);
    text-wrap: balance;
  }

  @media (width <= 880px) {
    .inner {
      grid-template-columns: 1fr;
    }
  }
}
</style>
