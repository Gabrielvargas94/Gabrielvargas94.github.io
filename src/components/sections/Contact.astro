---
import { getEntry } from 'astro:content';
import CTAButton from '../ui/CTAButton.astro';
import type { Locale } from '../../lib/i18n';
import uiEn from '../../content/ui/en.json';
import uiEs from '../../content/ui/es.json';
import uiPt from '../../content/ui/pt.json';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const uiByLocale = { en: uiEn, es: uiEs, pt: uiPt } as const;
const ui = uiByLocale[locale];
const s = ui.sections.contact;

const profile = await getEntry('profile', locale);
if (!profile) throw new Error(`Profile not found for locale ${locale}`);

const year = new Date().getFullYear();
---
<section id="contact" aria-labelledby="contact-title">
  <div class="halo" aria-hidden="true"></div>

  <div class="inner">
    <div class="kicker" aria-hidden="true">
      <span class="line"></span>
      {s.kicker}
      <span class="line"></span>
    </div>

    <h2 id="contact-title">
      {s.titlePre} <em>{s.titleEm}</em>
    </h2>

    <p class="body">{s.body}</p>

    <div class="cta-wrap">
      <CTAButton
        href={profile.data.linkedin}
        label={s.cta}
        icon="simple-icons:linkedin"
        variant="invert"
      />
    </div>
  </div>
</section>

<style lang="scss">
@layer components {
  section {
    position: relative;
    overflow: hidden;
    background: var(--ink);
    color: var(--cream);
    padding: clamp(120px, 14vw, 200px) clamp(16px, 4vw, 64px);
  }

  .halo {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background: radial-gradient(60% 60% at 50% 50%, rgb(201 122 75 / 22%), transparent 70%);
  }

  .inner {
    position: relative;
    max-width: 1100px;
    margin: 0 auto;
    text-align: center;
  }

  // Kicker with decorative horizontal lines on either side.
  .kicker {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 28px;
    font-family: var(--mono);
    font-size: 12px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: rgb(247 242 232 / 75%);
  }

  .line {
    display: block;
    width: 24px;
    height: 1px;
    background: rgb(247 242 232 / 55%);
  }

  h2 {
    margin: 0;
    font-family: var(--serif);
    font-size: clamp(40px, 8vw, 132px);
    line-height: 0.95;
    letter-spacing: -0.035em;
    font-weight: 400;
    color: var(--cream);
    text-wrap: balance;

    em {
      font-style: italic;
      color: var(--accent-light);
    }
  }

  // Narrow screens: tighten section padding so the big serif headline has
  // room to wrap without bumping the viewport edges.
  @media (width <= 560px) {
    section {
      padding: clamp(96px, 14vw, 160px) clamp(16px, 4vw, 64px);
    }

    .cta-wrap {
      margin-top: 40px;
    }
  }

  .body {
    margin: 28px auto 0;
    max-width: 520px;
    font-size: clamp(16px, 1.2vw, 20px);
    line-height: 1.55;
    color: rgb(247 242 232 / 82%);
    text-wrap: pretty;
  }

  .cta-wrap {
    display: inline-flex;
    margin-top: 56px;
  }
}
</style>
