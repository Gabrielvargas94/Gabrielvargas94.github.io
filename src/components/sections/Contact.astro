---
import { getEntry } from 'astro:content';
import CTAButton from '../ui/CTAButton.astro';
import type { Locale } from '../../lib/i18n';
import uiEn from '../../content/ui/en.json';
import uiEs from '../../content/ui/es.json';
import uiPt from '../../content/ui/pt.json';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const uiByLocale = { en: uiEn, es: uiEs, pt: uiPt } as const;
const ui = uiByLocale[locale];
const s = ui.sections.contact;

const profile = await getEntry('profile', locale);
if (!profile) throw new Error(`Profile not found for locale ${locale}`);
---
<section id="contact" aria-labelledby="contact-title">
  <div class="inner">
    <span class="kicker">{s.kicker}</span>
    <h2 id="contact-title">{s.title}</h2>
    <div class="cta-wrap">
      <CTAButton
        href={profile.data.linkedin}
        label={s.cta}
        icon="lucide:linkedin"
        variant="invert"
      />
    </div>
  </div>
</section>

<style lang="scss">
@layer components {
  section {
    background: var(--ink);
    color: var(--cream);
    padding: 120px clamp(16px, 4vw, 64px);
  }

  .inner {
    max-width: 800px;
    margin: 0 auto;
    text-align: center;
  }

  .kicker {
    display: inline-block;
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--accent-light);
    margin-bottom: 16px;
  }

  h2 {
    font-family: var(--serif);
    font-size: clamp(36px, 5vw, 64px);
    line-height: 1.1;
    letter-spacing: -0.02em;
    margin: 0 0 40px;
    color: var(--cream);
  }

  .cta-wrap {
    display: inline-flex;
  }
}
</style>
