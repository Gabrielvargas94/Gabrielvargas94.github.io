---
import Pill from '../ui/Pill.astro';
import Icon from '../ui/Icon.astro';
import type { Locale } from '../../lib/i18n';
import uiEn from '../../content/ui/en.json';
import uiEs from '../../content/ui/es.json';
import uiPt from '../../content/ui/pt.json';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const uiByLocale = { en: uiEn, es: uiEs, pt: uiPt } as const;
const ui = uiByLocale[locale];
const s = ui.sections.lectures;
---
<section id="lectures" aria-labelledby="lectures-title">
  <div class="inner">
    <header class="head">
      <Pill>
        <span class="mic" aria-hidden="true"><Icon name="lucide:mic" size={14} /></span>
        {s.kicker}
      </Pill>
      <h2 id="lectures-title">{s.title}</h2>
      <p class="body">{s.body}</p>
    </header>

    <ol class="talks">
      {s.talks.map((talk) => (
        <li class="talk-card">
          <span class="n" aria-hidden="true">{talk.n}</span>
          <div class="talk-body">
            <h3>{talk.title}</h3>
            <p>{talk.body}</p>
          </div>
          <span class="play" aria-hidden="true">
            <Icon name="lucide:arrow-down" size={18} />
          </span>
        </li>
      ))}
    </ol>
  </div>
</section>

<style lang="scss">
@layer components {
  section {
    background: var(--cream);
    padding: clamp(80px, 10vw, 140px) clamp(16px, 4vw, 64px);
  }

  .inner {
    max-width: 1320px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: minmax(280px, 420px) 1fr;
    gap: clamp(40px, 6vw, 96px);
    align-items: start;
  }

  .head {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .mic {
    display: inline-flex;
    margin-right: 2px;
  }

  h2 {
    margin: 0;
    font-family: var(--serif);
    font-size: clamp(36px, 4.8vw, 64px);
    line-height: 1.02;
    letter-spacing: -0.025em;
    font-weight: 400;
    color: var(--ink);
    text-wrap: balance;
  }

  .body {
    margin: 0;
    font-size: 17px;
    line-height: 1.6;
    color: var(--ink-2);
    text-wrap: pretty;
  }

  .talks {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 18px;
  }

  .talk-card {
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: 28px;
    align-items: start;
    padding: clamp(28px, 3vw, 36px);
    background: var(--cream-2);
    border: 1px solid rgb(42 33 27 / 10%);
    border-radius: 20px;
    transition:
      transform 0.4s cubic-bezier(0.2, 0.8, 0.2, 1),
      background 0.4s cubic-bezier(0.2, 0.8, 0.2, 1),
      box-shadow 0.4s cubic-bezier(0.2, 0.8, 0.2, 1);

    &:hover {
      background: var(--paper);
      transform: translateX(6px);
      box-shadow: 0 12px 32px rgb(42 33 27 / 8%);

      .play {
        transform: translateX(4px);
      }
    }
  }

  .n {
    min-width: 60px;
    font-family: var(--serif);
    font-style: italic;
    font-size: clamp(36px, 4vw, 44px);
    line-height: 1;
    color: var(--accent-dark);
  }

  .talk-body {
    h3 {
      margin: 0;
      font-family: var(--serif);
      font-size: clamp(22px, 2vw, 30px);
      line-height: 1.2;
      letter-spacing: -0.015em;
      font-weight: 400;
      color: var(--ink);
    }

    p {
      margin: 12px 0 0;
      font-size: 16px;
      line-height: 1.55;
      color: var(--ink-2);
      text-wrap: pretty;
    }
  }

  .play {
    display: inline-flex;
    align-items: center;
    padding-top: 6px;
    color: var(--ink-3);
    transition: transform 0.3s;
  }

  @media (width <= 880px) {
    .inner {
      grid-template-columns: 1fr;
    }

    .talk-card {
      grid-template-columns: auto 1fr;
    }

    .play {
      display: none;
    }
  }
}
</style>
