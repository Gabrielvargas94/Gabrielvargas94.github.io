---
import type { Locale } from '../../lib/i18n';
import uiEn from '../../content/ui/en.json';
import uiEs from '../../content/ui/es.json';
import uiPt from '../../content/ui/pt.json';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const uiByLocale = { en: uiEn, es: uiEs, pt: uiPt } as const;
const ui = uiByLocale[locale];
const s = ui.sections.ittiAi;
---
<section id="itti-ai" aria-labelledby="itti-ai-title">
  <div class="inner">
    <div class="copy">
      <span class="kicker">{s.kicker}</span>
      <h2 id="itti-ai-title">{s.title}</h2>
      <p>{s.desc}</p>
    </div>

    <div class="terminal">
      <div class="bar" aria-hidden="true">
        <span class="dot dot-r"></span>
        <span class="dot dot-y"></span>
        <span class="dot dot-g"></span>
      </div>
      <pre class="term" aria-label="Claude Code terminal example"><code>$ claude
<span class="cmd">&gt;</span> roll out claude code to engineering org
<span class="ok">&#10003;</span> 40-person core team onboarded
<span class="ok">&#10003;</span> harness wired
<span class="ok">&#10003;</span> incident playbook updated
<span class="cmd">_</span></code></pre>
    </div>
  </div>
</section>

<style lang="scss">
@layer components {
  section {
    background: var(--cream);
    padding: 100px clamp(16px, 4vw, 64px);
  }

  .inner {
    max-width: 1280px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 64px;
    align-items: center;
  }

  .kicker {
    display: inline-block;
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--accent-dark);
    margin-bottom: 12px;
  }

  h2 {
    font-family: var(--serif);
    font-size: clamp(36px, 5vw, 56px);
    line-height: 1.1;
    letter-spacing: -0.02em;
    margin: 0 0 20px;
    color: var(--ink);
  }

  .copy p {
    margin: 0;
    color: var(--ink-2);
    font-size: 17px;
    line-height: 1.6;
  }

  .terminal {
    background: var(--ink);
    border-radius: 14px;
    overflow: hidden;
    box-shadow: 0 20px 60px rgb(42 33 27 / 25%);
  }

  .bar {
    display: flex;
    gap: 8px;
    padding: 12px 16px;
    background: rgb(247 242 232 / 8%);
    border-bottom: 1px solid rgb(247 242 232 / 8%);
  }

  .dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
  }

  .dot-r {
    background: #e3624b;
  }

  .dot-y {
    background: #e3a76b;
  }

  .dot-g {
    background: #5b9a6e;
  }

  .term {
    margin: 0;
    padding: 24px;
    color: var(--cream);
    font-family: var(--mono);
    font-size: 14px;
    line-height: 1.7;
    overflow-x: auto;
  }

  .cmd {
    color: var(--accent-light);
  }

  .ok {
    color: #5b9a6e;
  }

  @media (width <= 880px) {
    .inner {
      grid-template-columns: 1fr;
      gap: 40px;
    }

    .term {
      font-size: 13px;
    }
  }
}
</style>
