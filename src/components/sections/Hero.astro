---
import { Image } from 'astro:assets';
import { getEntry } from 'astro:content';
import CTAButton from '../ui/CTAButton.astro';
import Pill from '../ui/Pill.astro';
import gabrielImg from '../../../public/assets/gabriel.png';
import type { Locale } from '../../lib/i18n';
import uiEn from '../../content/ui/en.json';
import uiEs from '../../content/ui/es.json';
import uiPt from '../../content/ui/pt.json';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;

const profile = await getEntry('profile', locale);
if (!profile) throw new Error(`Profile not found for locale ${locale}`);

const uiByLocale = { en: uiEn, es: uiEs, pt: uiPt } as const;
const ui = uiByLocale[locale];
// Split into parts so the status badge can wrap to multiple lines on narrow
// screens — rendering it as a single text node would force a horizontal
// scrollbar at 320px (uppercase + 0.16em tracking is too wide).
const locMetaParts: Record<Locale, readonly string[]> = {
  en: ['Buenos Aires', 'Remote', 'Relocation'],
  es: ['Buenos Aires', 'Remoto', 'Reubicación'],
  pt: ['Buenos Aires', 'Remoto', 'Realocação'],
};
const parts = locMetaParts[locale];
---
<section id="hero" aria-labelledby="hero-title">
  <div class="grain" aria-hidden="true"></div>

  <aside class="status" aria-hidden="true">
    <div class="status-row">
      {parts.map((p, i) => (
        <>
          {i > 0 && <span class="sep">·</span>}
          <span>{p}</span>
        </>
      ))}
    </div>
  </aside>

  <div class="inner">
    <div class="copy">
      <Pill>{ui.hero.kicker}</Pill>
      <h1 id="hero-title">
        {ui.hero.titlePre}{' '}
        <em>{ui.hero.titleEm}</em>{ui.hero.titlePost ? ' ' : ''}
        {ui.hero.titlePost}
      </h1>
      <p class="sub">{ui.hero.subhead}</p>
      <div class="actions">
        <CTAButton href={profile.data.linkedin} label={ui.hero.cta} icon="simple-icons:linkedin" />
        <span class="years">
          <span class="dot" aria-hidden="true"></span>
          {ui.hero.yearsMeta}
        </span>
      </div>
      <div class="scroll-cue" aria-hidden="true">
        <span class="arrow">↓</span> {ui.hero.scrollHint}
      </div>
    </div>

    <div class="photo">
      <div class="frame">
        <div class="blob" aria-hidden="true"></div>
        <span class="corner tl" aria-hidden="true"></span>
        <span class="corner tr" aria-hidden="true"></span>
        <span class="corner bl" aria-hidden="true"></span>
        <span class="corner br" aria-hidden="true"></span>
        <Image
          src={gabrielImg}
          alt={`${profile.data.name}, ${profile.data.displayTitle}`}
          widths={[320, 480, 640, 960]}
          sizes="(max-width: 560px) 320px, (max-width: 880px) 480px, 640px"
          loading="eager"
          decoding="async"
          fetchpriority="high"
        />
      </div>
    </div>
  </div>
</section>

<style lang="scss">
@layer components {
  section {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    padding: 120px clamp(16px, 4vw, 64px) 80px;
    background: var(--cream);
    overflow: hidden;
  }

  .grain {
    position: absolute;
    inset: 0;
    pointer-events: none;
    opacity: 0.4;
    background-image:
      radial-gradient(circle at 20% 30%, rgb(201 122 75 / 8%) 0%, transparent 40%),
      radial-gradient(circle at 80% 70%, rgb(201 122 75 / 6%) 0%, transparent 45%);
  }

  // Floating "open / location" meta in the top-right corner of the section.
  .status {
    position: absolute;
    top: clamp(80px, 10vw, 120px);
    right: clamp(16px, 4vw, 64px);
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 6px;
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--ink-3);
    z-index: 2;
  }

  .status-row {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 4px 8px;
    max-width: 100%;
  }

  // Hide the separator when it ends up at line start after wrapping
  // (clean visual: no dangling middle dots floating at column edge).
  .sep {
    color: var(--ink-3);
    opacity: 0.6;
  }

  .pulse {
    position: relative;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #5b9a6e;

    &::after {
      content: '';
      position: absolute;
      inset: 0;
      border-radius: 50%;
      background: #5b9a6e;
      animation: pulse-grow 2s ease-out infinite;
    }
  }

  @keyframes pulse-grow {
    0%   { transform: scale(1); opacity: 0.5; }
    100% { transform: scale(3); opacity: 0; }
  }

  .inner {
    position: relative;
    z-index: 1;
    max-width: 1440px;
    width: 100%;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1.05fr 0.95fr;
    gap: clamp(24px, 4vw, 72px);
    align-items: center;
  }

  h1 {
    font-family: var(--serif);
    font-size: clamp(48px, 7vw, 108px);
    line-height: 0.98;
    letter-spacing: -0.03em;
    font-weight: 400;
    margin: 28px 0 0;
    color: var(--ink);
    text-wrap: balance;

    em {
      font-style: italic;
      color: var(--accent);
      font-family: var(--serif);
      font-weight: 400;
    }
  }

  .sub {
    margin: 32px 0 0;
    max-width: 560px;
    font-size: clamp(16px, 1.3vw, 20px);
    line-height: 1.55;
    color: var(--ink-2);
    text-wrap: pretty;
  }

  .actions {
    margin-top: 44px;
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 20px;
  }

  .years {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--mono);
    font-size: 12px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--ink-3);

    .dot {
      width: 5px;
      height: 5px;
      border-radius: 50%;
      background: var(--accent-dark);
    }
  }

  .scroll-cue {
    margin-top: clamp(48px, 6vw, 88px);
    display: inline-flex;
    align-items: center;
    gap: 12px;
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--ink-3);
  }

  .arrow {
    display: inline-block;
    animation: bob 2.4s ease-in-out infinite;
  }

  @keyframes bob {
    0%, 100% { transform: translateY(0); }
    50%      { transform: translateY(4px); }
  }

  // Photo frame: corner ticks + radial accent blob + drop shadow.
  .photo {
    display: flex;
    justify-content: flex-end;
  }

  .frame {
    position: relative;
    width: min(100%, 560px);
  }

  .blob {
    position: absolute;
    inset: -8% -6%;
    background: radial-gradient(60% 60% at 50% 55%, rgb(201 122 75 / 18%), transparent 70%);
    filter: blur(20px);
    z-index: 0;
    pointer-events: none;
  }

  .corner {
    position: absolute;
    width: 28px;
    height: 28px;
    border-top: 1.5px solid var(--ink);
    border-left: 1.5px solid var(--ink);
    opacity: 0.55;
    z-index: 2;
  }
  .corner.tl { top: -14px; left: -14px; }
  .corner.tr { top: -14px; right: -14px; transform: rotate(90deg); }
  .corner.bl { bottom: -14px; left: -14px; transform: rotate(-90deg); }
  .corner.br { bottom: -14px; right: -14px; transform: rotate(180deg); }

  .photo :global(img) {
    position: relative;
    z-index: 1;
    display: block;
    width: 100%;
    height: auto;
    filter: drop-shadow(0 24px 40px rgb(42 33 27 / 18%));
  }

  // Responsive collapse.
  @media (width <= 880px) {
    section {
      min-height: auto;
      padding-top: 110px;
    }

    // Don't override position here — the desktop position:absolute keeps the
    // status pinned to its corner. Anything that puts it back into flow
    // (relative / static) breaks the responsive layout in this section.
    .status {
      top: auto;
      right: auto;
      align-items: flex-start;
      margin-bottom: 24px;
    }

    .inner {
      grid-template-columns: 1fr;
      gap: 40px;
    }

    .photo {
      justify-content: center;
    }

    .frame {
      max-width: 380px;
    }
  }

  // Very narrow: tighten the status badge so 3 chips fit ≤380px without
  // line-breaking awkwardly. PT's "Realocação" is the longest token.
  @media (width <= 400px) {
    .status {
      font-size: 10px;
      letter-spacing: 0.08em;
    }
  }
}
</style>
