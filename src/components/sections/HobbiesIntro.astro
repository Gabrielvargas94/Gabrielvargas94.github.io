---
import type { Locale } from '../../lib/i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;

const labels: Record<Locale, { kicker: string; title: string; desc: string }> = {
  en: {
    kicker: 'Beyond Engineering',
    title: 'My Hobbies',
    desc: 'Where curiosity goes after work hours.',
  },
  es: {
    kicker: 'Más allá de la ingeniería',
    title: 'Mis Hobbies',
    desc: 'A dónde va la curiosidad después del trabajo.',
  },
  pt: {
    kicker: 'Além da engenharia',
    title: 'Meus Hobbies',
    desc: 'Para onde vai a curiosidade depois do trabalho.',
  },
};

const l = labels[locale];
---
<section id="hobbies-intro" aria-labelledby="hobbies-intro-title">
  <div class="inner">
    <span class="kicker">{l.kicker}</span>
    <h2 id="hobbies-intro-title">{l.title}</h2>
    <p>{l.desc}</p>
  </div>
</section>

<style lang="scss">
@layer components {
  section {
    background: var(--cream);
    padding: 80px clamp(16px, 4vw, 64px);
  }

  .inner {
    max-width: 800px;
    margin: 0 auto;
    text-align: center;
  }

  .kicker {
    display: inline-block;
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--accent-dark);
    margin-bottom: 12px;
  }

  h2 {
    font-family: var(--serif);
    font-size: clamp(36px, 5vw, 56px);
    line-height: 1.1;
    letter-spacing: -0.02em;
    margin: 0 0 16px;
    color: var(--ink);
  }

  p {
    margin: 0;
    font-size: 17px;
    line-height: 1.6;
    color: var(--ink-2);
  }
}
</style>
