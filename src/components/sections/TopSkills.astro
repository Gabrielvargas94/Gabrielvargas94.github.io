---
import Icon from '../ui/Icon.astro';
import type { Locale } from '../../lib/i18n';
import uiEn from '../../content/ui/en.json';
import uiEs from '../../content/ui/es.json';
import uiPt from '../../content/ui/pt.json';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const uiByLocale = { en: uiEn, es: uiEs, pt: uiPt } as const;
const ui = uiByLocale[locale];
const s = ui.sections.topSkills;
---
<section id="top-skills" aria-labelledby="top-skills-title">
  <div class="inner">
    <header class="head">
      <span class="kicker">{s.kicker}</span>
      <h2 id="top-skills-title">{s.title}</h2>
      <p class="lead">{s.desc}</p>
    </header>

    <ul class="grid">
      {
        s.items.map((it) => (
          <li class="card">
            <span class="icon" aria-hidden="true">
              <Icon name={it.icon} size={28} />
            </span>
            <h3>{it.title}</h3>
            <p>{it.desc}</p>
          </li>
        ))
      }
    </ul>
  </div>
</section>

<style lang="scss">
@layer components {
  section {
    background: var(--cream-2);
    padding: clamp(64px, 8vw, 100px) clamp(16px, 4vw, 64px);
  }

  .inner {
    max-width: 1200px;
    margin: 0 auto;
  }

  .head {
    text-align: center;
    margin-bottom: clamp(32px, 5vw, 56px);
  }

  .kicker {
    display: inline-block;
    margin-bottom: 12px;
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--accent-dark);
  }

  h2 {
    margin: 0 0 16px;
    font-family: var(--serif);
    font-size: clamp(32px, 5vw, 56px);
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: var(--ink);
  }

  .lead {
    margin: 0 auto;
    max-width: 600px;
    color: var(--ink-2);
    font-size: 16px;
    line-height: 1.55;
  }

  .grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }

  .card {
    padding: 28px;
    background: var(--paper);
    border: 1px solid rgb(42 33 27 / 8%);
    border-radius: 16px;
    display: flex;
    flex-direction: column;
    gap: 14px;
    transition: transform 0.2s, box-shadow 0.2s;

    &:hover {
      transform: translateY(-2px);
      box-shadow: 0 14px 36px rgb(42 33 27 / 10%);
    }
  }

  .icon {
    display: grid;
    place-items: center;
    width: 52px;
    height: 52px;
    border-radius: 14px;
    background: var(--ink);
    color: var(--accent-light);
  }

  h3 {
    margin: 0;
    font-family: var(--serif);
    font-size: 22px;
    line-height: 1.2;
    color: var(--ink);
  }

  p {
    margin: 0;
    font-size: 14.5px;
    line-height: 1.55;
    color: var(--ink-2);
  }

  @media (width <= 880px) {
    .grid {
      grid-template-columns: 1fr;
    }
  }
}
</style>
