---
import Pill from '../ui/Pill.astro';
import Icon from '../ui/Icon.astro';
import type { Locale } from '../../lib/i18n';
import uiEn from '../../content/ui/en.json';
import uiEs from '../../content/ui/es.json';
import uiPt from '../../content/ui/pt.json';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const uiByLocale = { en: uiEn, es: uiEs, pt: uiPt } as const;
const ui = uiByLocale[locale];
const s = ui.sections.idb;
---
<section id="idb" aria-labelledby="idb-title">
  <div class="inner">
    <aside class="meta">
      <span class="icon-box" aria-hidden="true">
        <Icon name="lucide:award" size={36} />
      </span>
      <Pill>{s.kicker}</Pill>
      <span class="meta-title">{s.metaTitle}</span>
    </aside>

    <div class="content">
      <h2 id="idb-title">{s.org}</h2>
      <p class="lede">{s.lede}</p>

      <dl class="stats">
        {s.stats.map((stat) => (
          <div class="stat">
            <dt>{stat.n}</dt>
            <dd>{stat.l}</dd>
          </div>
        ))}
      </dl>

      <p class="body">{s.body}</p>
    </div>
  </div>
</section>

<style lang="scss">
@layer components {
  section {
    background: var(--cream-2);
    padding: clamp(80px, 10vw, 140px) clamp(16px, 4vw, 64px);
  }

  .inner {
    max-width: 1320px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: minmax(280px, 380px) 1fr;
    gap: clamp(40px, 6vw, 100px);
    align-items: start;
  }

  .meta {
    position: sticky;
    top: 100px;
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .icon-box {
    display: grid;
    place-items: center;
    width: 80px;
    height: 80px;
    border-radius: 18px;
    background: var(--ink);
    color: var(--cream);
  }

  .meta-title {
    font-family: var(--mono);
    font-size: 12px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--ink-3);
  }

  .content {
    display: flex;
    flex-direction: column;
    gap: 28px;
  }

  h2 {
    margin: 0;
    font-family: var(--serif);
    font-size: clamp(36px, 5vw, 72px);
    line-height: 1;
    letter-spacing: -0.025em;
    font-weight: 400;
    color: var(--ink);
    text-wrap: balance;
  }

  .lede {
    margin: 0;
    max-width: 680px;
    font-size: clamp(17px, 1.4vw, 22px);
    line-height: 1.55;
    color: var(--ink-2);
    text-wrap: pretty;
  }

  .stats {
    margin: clamp(28px, 4vw, 40px) 0 0;
    padding-top: 36px;
    border-top: 1px solid rgb(42 33 27 / 12%);
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 24px;
  }

  .stat {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  dt {
    font-family: var(--serif);
    font-size: clamp(40px, 4.8vw, 64px);
    line-height: 1;
    letter-spacing: -0.03em;
    font-weight: 400;
    color: var(--accent-dark);
  }

  dd {
    margin: 0;
    max-width: 220px;
    font-size: 14px;
    line-height: 1.5;
    color: var(--ink-2);
  }

  .body {
    margin: clamp(28px, 4vw, 48px) 0 0;
    max-width: 680px;
    padding-left: 24px;
    border-left: 2px solid var(--accent-dark);
    font-family: var(--serif);
    font-style: italic;
    font-size: 16px;
    line-height: 1.65;
    color: var(--ink-3);
  }

  @media (width <= 880px) {
    .inner {
      grid-template-columns: 1fr;
    }

    .meta {
      position: static;
      flex-direction: row;
      align-items: center;
      gap: 16px;
      flex-wrap: wrap;
    }
  }
}
</style>
