---
import VideoPlaceholder from '../ui/VideoPlaceholder.astro';
import Pill from '../ui/Pill.astro';
import type { Locale } from '../../lib/i18n';
import uiEn from '../../content/ui/en.json';
import uiEs from '../../content/ui/es.json';
import uiPt from '../../content/ui/pt.json';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const uiByLocale = { en: uiEn, es: uiEs, pt: uiPt } as const;
const ui = uiByLocale[locale];
const s = ui.sections.sideProject;
---
<section id="side-project" aria-labelledby="side-project-title">
  <div class="bg" aria-hidden="true">
    <VideoPlaceholder label="D&D AI Companion" tint="var(--accent-dark)" />
  </div>

  <div class="inner">
    <header class="head">
      <div class="lede-col">
        <Pill variant="dark">{s.kicker}</Pill>
        <h2 id="side-project-title">{s.title}</h2>
      </div>
      <p class="lede">{s.lede}</p>
    </header>

    <ul class="cards">
      {s.cards.map((c, i) => (
        <li class="card">
          <div class="card-tag">
            <span class="num" aria-hidden="true">{String(i + 1).padStart(2, '0')}</span>
            <span>{c.tag}</span>
          </div>
          <h3>{c.title}</h3>
          <p>{c.body}</p>
        </li>
      ))}
    </ul>
  </div>
</section>

<style lang="scss">
@layer components {
  section {
    position: relative;
    isolation: isolate;
    padding: clamp(96px, 11vw, 160px) clamp(16px, 4vw, 64px);
    overflow: clip;
    background-color: var(--ink);
    color: var(--cream);
  }

  .bg {
    position: absolute;
    inset: 0;
    z-index: -1;
  }

  .bg::after {
    content: '';
    position: absolute;
    inset: 0;
    background: rgb(20 10 28 / 70%);
  }

  .inner {
    position: relative;
    max-width: 1320px;
    margin: 0 auto;
  }

  .head {
    display: grid;
    grid-template-columns: 1.05fr 0.95fr;
    gap: clamp(32px, 5vw, 80px);
    align-items: end;
    margin-bottom: clamp(48px, 6vw, 80px);
  }

  .lede-col {
    display: flex;
    flex-direction: column;
    gap: 20px;
    max-width: 620px;
  }

  h2 {
    margin: 0;
    font-family: var(--serif);
    font-size: clamp(36px, 5vw, 64px);
    line-height: 1.05;
    letter-spacing: -0.025em;
    font-weight: 400;
    color: var(--cream);
    text-wrap: balance;
  }

  .lede {
    margin: 0;
    max-width: 560px;
    font-size: clamp(15px, 1.1vw, 18px);
    line-height: 1.6;
    color: rgb(247 242 232 / 80%);
    text-wrap: pretty;
  }

  .cards {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 18px;
  }

  .card {
    display: flex;
    flex-direction: column;
    gap: 12px;
    min-height: 220px;
    padding: 28px 26px 26px;
    background: rgb(247 242 232 / 5%);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid rgb(247 242 232 / 14%);
    border-radius: 16px;
    transition:
      transform 0.35s cubic-bezier(0.2, 0.8, 0.2, 1),
      background 0.35s cubic-bezier(0.2, 0.8, 0.2, 1);

    &:hover {
      background: rgb(247 242 232 / 10%);
      transform: translateY(-3px);
    }
  }

  .card-tag {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: rgb(247 242 232 / 55%);
  }

  .num {
    color: var(--accent-light);
  }

  h3 {
    margin: 0;
    font-family: var(--serif);
    font-size: 22px;
    line-height: 1.2;
    letter-spacing: -0.01em;
    font-weight: 400;
    color: var(--cream);
  }

  .card p {
    margin: 0;
    font-size: 14.5px;
    line-height: 1.55;
    color: rgb(247 242 232 / 72%);
    text-wrap: pretty;
  }

  @media (width <= 880px) {
    .head {
      grid-template-columns: 1fr;
      align-items: start;
    }
  }
}
</style>
