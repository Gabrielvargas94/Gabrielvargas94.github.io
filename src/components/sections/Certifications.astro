---
import { getCollection } from 'astro:content';
import Pill from '../ui/Pill.astro';
import Icon from '../ui/Icon.astro';
import type { Locale } from '../../lib/i18n';
import uiEn from '../../content/ui/en.json';
import uiEs from '../../content/ui/es.json';
import uiPt from '../../content/ui/pt.json';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const uiByLocale = { en: uiEn, es: uiEs, pt: uiPt } as const;
const ui = uiByLocale[locale];
const s = ui.sections.certs;

// Only show Anthropic AI certifications in the section grid. Other credentials
// (e.g. Cambridge FCE language cert) still flow into cv.md / cv.json / cv.pdf.
const certs = (
  await getCollection(
    'certification',
    (c) => c.data.locale === locale && c.data.issuer === 'Anthropic',
  )
).sort((a, b) => b.data.date.localeCompare(a.data.date));

const doneLabel: Record<Locale, string> = {
  en: 'Completed',
  es: 'Completado',
  pt: 'Completado',
};
const inProgressLabel: Record<Locale, string> = {
  en: 'In progress',
  es: 'En progreso',
  pt: 'Em andamento',
};
const bodyLabel: Record<Locale, string> = {
  en: 'Anthropic certifications focused on Claude API, Claude Code, MCP, subagents and agent skills.',
  es: 'Certificaciones de Anthropic enfocadas en Claude API, Claude Code, MCP, subagentes y agent skills.',
  pt: 'Certificações da Anthropic focadas em Claude API, Claude Code, MCP, subagents e agent skills.',
};

function formatDate(date: string, loc: Locale): string {
  const [year, month] = date.split('-');
  const monthIndex = Number(month) - 1;
  const monthNames: Record<Locale, readonly string[]> = {
    en: ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'],
    es: ['Ene', 'Feb', 'Mar', 'Abr', 'May', 'Jun', 'Jul', 'Ago', 'Sep', 'Oct', 'Nov', 'Dic'],
    pt: ['Jan', 'Fev', 'Mar', 'Abr', 'Mai', 'Jun', 'Jul', 'Ago', 'Set', 'Out', 'Nov', 'Dez'],
  };
  return `${monthNames[loc][monthIndex] ?? ''} ${year}`;
}
---
<section id="certs" aria-labelledby="certs-title">
  <div class="inner">
    <aside class="head" aria-labelledby="certs-title">
      <span class="badge" aria-hidden="true">
        <Icon name="lucide:award" size={32} />
      </span>
      <Pill>{s.kicker}</Pill>
      <h2 id="certs-title">{s.title}</h2>
      <p class="body">{bodyLabel[locale]}</p>
      <p class="subtitle">{s.subtitle}</p>
    </aside>

    <ol class="list">
      {certs.map((cert) => {
        const isDone = cert.data.status === 'completed';
        return (
          <li class:list={['row', { 'row-done': isDone, 'row-progress': !isDone }]}>
            <span class="status" aria-hidden="true">
              {isDone ? <Icon name="lucide:award" size={16} /> : <Icon name="lucide:arrow-down" size={16} />}
            </span>
            <span class="name">{cert.data.name}</span>
            <span class="status-label">
              {isDone ? doneLabel[locale] : inProgressLabel[locale]}
            </span>
            <time datetime={cert.data.date}>{formatDate(cert.data.date, locale)}</time>
          </li>
        );
      })}
    </ol>
  </div>
</section>

<style lang="scss">
@layer components {
  section {
    background: var(--cream);
    padding: clamp(80px, 10vw, 140px) clamp(16px, 4vw, 64px);
  }

  .inner {
    max-width: 1320px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: minmax(280px, 380px) 1fr;
    gap: clamp(40px, 6vw, 96px);
    align-items: start;
  }

  .head {
    position: sticky;
    top: 100px;
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .badge {
    display: grid;
    place-items: center;
    width: 64px;
    height: 64px;
    border-radius: 14px;
    background: var(--ink);
    color: var(--accent-light);
  }

  h2 {
    margin: 0;
    font-family: var(--serif);
    font-size: clamp(32px, 4vw, 56px);
    line-height: 1.05;
    letter-spacing: -0.025em;
    font-weight: 400;
    color: var(--ink);
    text-wrap: balance;
  }

  .body {
    margin: 0;
    font-size: 16px;
    line-height: 1.6;
    color: var(--ink-2);
    text-wrap: pretty;
  }

  .subtitle {
    margin: 0;
    font-size: 14px;
    color: var(--ink-3);
  }

  .list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0;
  }

  .row {
    display: grid;
    grid-template-columns: auto 1fr auto auto;
    gap: 24px;
    align-items: center;
    padding: 22px 4px;
    border-bottom: 1px solid rgb(42 33 27 / 10%);
    transition: background 0.2s;

    &:last-child {
      border-bottom: none;
    }

    &:hover {
      background: rgb(42 33 27 / 3%);
    }
  }

  .status {
    display: grid;
    place-items: center;
    width: 36px;
    height: 36px;
    border-radius: 50%;
  }

  .row-done .status {
    background: var(--accent-dark);
    color: var(--cream);
  }

  .row-progress .status {
    background: rgb(42 33 27 / 6%);
    color: var(--ink-3);
  }

  .name {
    font-family: var(--serif);
    font-size: clamp(17px, 1.4vw, 22px);
    line-height: 1.25;
    letter-spacing: -0.01em;
    color: var(--ink);
  }

  .status-label {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .row-done .status-label {
    color: var(--accent-dark);
  }

  .row-progress .status-label {
    color: var(--ink-3);
  }

  time {
    min-width: 90px;
    font-family: var(--mono);
    font-size: 12px;
    color: var(--ink-3);
    text-align: right;
  }

  @media (width <= 880px) {
    .inner {
      grid-template-columns: 1fr;
    }

    .head {
      position: static;
    }

    .row {
      grid-template-columns: auto 1fr;
      grid-template-rows: auto auto;
      row-gap: 4px;
    }

    .status {
      grid-row: span 2;
    }

    .status-label,
    time {
      grid-column: 2;
      justify-self: start;
      text-align: left;
    }
  }
}
</style>
