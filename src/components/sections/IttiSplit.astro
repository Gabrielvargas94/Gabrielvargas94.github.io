---
import { Image } from 'astro:assets';
import VideoPlaceholder from '../ui/VideoPlaceholder.astro';
import ittiLogo from '../../../public/assets/itti-logo.png';
import type { Locale } from '../../lib/i18n';
import uiEn from '../../content/ui/en.json';
import uiEs from '../../content/ui/es.json';
import uiPt from '../../content/ui/pt.json';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const uiByLocale = { en: uiEn, es: uiEs, pt: uiPt } as const;
const ui = uiByLocale[locale];
const s = ui.sections.ittiSplit;
---
<section id="work" aria-labelledby="itti-split-title">
  <header class="head">
    <span class="kicker">{s.kicker}</span>
    <h2 id="itti-split-title">{s.title}</h2>
  </header>

  <div class="split">
    <article class="side">
      <div class="bg" aria-hidden="true">
        <VideoPlaceholder label={s.left} youtubeId="NG_xGUvlNl0" />
      </div>
      <div class="overlay">
        <h3>{s.left}</h3>
        <p>{s.leftDesc}</p>
      </div>
    </article>

    <Image
      class="logo"
      src={ittiLogo}
      alt="itti"
      widths={[180, 280, 420]}
      sizes="(max-width: 720px) 160px, 280px"
      loading="lazy"
      decoding="async"
    />

    <article class="side">
      <div class="bg" aria-hidden="true">
        <VideoPlaceholder label={s.right} tint="var(--accent-dark)" youtubeId="ffQv3wXQlEU" />
      </div>
      <div class="overlay">
        <h3>{s.right}</h3>
        <p>{s.rightDesc}</p>
      </div>
    </article>
  </div>
</section>

<style lang="scss">
@layer components {
  section {
    background: var(--ink);
    color: var(--cream);
    padding: clamp(64px, 8vw, 100px) clamp(16px, 4vw, 64px);
  }

  .head {
    text-align: center;
    max-width: 900px;
    margin: 0 auto clamp(32px, 5vw, 56px);
  }

  .kicker {
    display: inline-block;
    margin-bottom: 12px;
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--accent-light);
  }

  h2 {
    margin: 0;
    font-family: var(--serif);
    font-size: clamp(32px, 5vw, 56px);
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: var(--cream);
  }

  // Split: two full-bleed video sides with logo overlay at the seam.
  .split {
    position: relative;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2px;
    max-width: 1600px;
    margin: 0 auto;
    border-radius: 18px;
    overflow: hidden;
  }

  .side {
    position: relative;
    isolation: isolate;
    min-height: clamp(380px, 52vh, 520px);
    overflow: hidden;
    background-color: #000000;
  }

  // Video (or placeholder) fills the side as background.
  .bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  // Light scrim across the whole video for ambient mood.
  .bg::after {
    content: '';
    position: absolute;
    inset: 0;
    background: rgb(0 0 0 / 25%);
    pointer-events: none;
  }

  .overlay {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    gap: 8px;
    justify-content: flex-end;
    height: 100%;
    padding: clamp(20px, 4vw, 40px);
    color: var(--cream);

    // Solid dark scrim ONLY behind the text region — guarantees AA contrast
    // regardless of underlying video frame.
    &::before {
      content: '';
      position: absolute;
      inset: 0;
      background: linear-gradient(
        to top,
        rgb(0 0 0 / 92%) 0%,
        rgb(0 0 0 / 78%) 45%,
        rgb(0 0 0 / 0%) 100%
      );
      z-index: -1;
      pointer-events: none;
    }
  }

  h3 {
    margin: 0;
    font-family: var(--serif);
    font-size: clamp(28px, 4vw, 44px);
    line-height: 1.1;
    letter-spacing: -0.01em;
  }

  .overlay p {
    margin: 0;
    max-width: 420px;
    font-size: clamp(14px, 1.6vw, 17px);
    line-height: 1.55;
    color: rgb(247 242 232 / 92%);
  }

  // Logo absolutely centered over the seam, on top of both videos.
  .logo {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    z-index: 3;
    width: clamp(120px, 18%, 240px);
    height: auto;
    pointer-events: none;
    user-select: none;
    filter: drop-shadow(0 6px 28px rgb(0 0 0 / 55%));
  }

  // Mobile: stack the two sides vertically, logo static between them.
  @media (width <= 720px) {
    .split {
      grid-template-columns: 1fr;
      gap: 0;
    }

    .side {
      min-height: clamp(320px, 48vh, 440px);
    }

    .logo {
      // Place logo at the seam between stacked sides via static rendering.
      position: relative;
      top: auto;
      left: auto;
      transform: none;
      width: clamp(96px, 28%, 160px);
      margin: -28px auto;
      filter: drop-shadow(0 4px 16px rgb(0 0 0 / 50%));
    }
  }
}
</style>
