---
import { Image } from 'astro:assets';
import VideoPlaceholder from '../ui/VideoPlaceholder.astro';
import ittiLogo from '../../../public/assets/itti-logo.png';
import type { Locale } from '../../lib/i18n';
import uiEn from '../../content/ui/en.json';
import uiEs from '../../content/ui/es.json';
import uiPt from '../../content/ui/pt.json';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const uiByLocale = { en: uiEn, es: uiEs, pt: uiPt } as const;
const ui = uiByLocale[locale];
const s = ui.sections.ittiSplit;
---
<section id="work" aria-labelledby="itti-split-title">
  <div class="inner">
    <header class="head">
      <span class="kicker">{s.kicker}</span>
      <h2 id="itti-split-title">{s.title}</h2>
    </header>

    <div class="split">
      <div class="videos">
        <div class="vid vid-left">
          <VideoPlaceholder label={s.left} youtubeId="NG_xGUvlNl0" />
        </div>
        <Image
          class="logo"
          src={ittiLogo}
          alt="itti"
          widths={[180, 280, 420]}
          sizes="(max-width: 720px) 180px, 280px"
          loading="lazy"
          decoding="async"
        />
        <div class="vid vid-right">
          <VideoPlaceholder label={s.right} tint="var(--accent-dark)" youtubeId="ffQv3wXQlEU" />
        </div>
      </div>

      <div class="captions">
        <article class="side">
          <h3>{s.left}</h3>
          <p>{s.leftDesc}</p>
        </article>
        <article class="side">
          <h3>{s.right}</h3>
          <p>{s.rightDesc}</p>
        </article>
      </div>
    </div>
  </div>
</section>

<style lang="scss">
@layer components {
  section {
    background: var(--paper);
    padding: 100px clamp(16px, 4vw, 64px);
  }

  .inner {
    max-width: 1440px;
    margin: 0 auto;
  }

  .head {
    text-align: center;
    margin-bottom: 64px;
  }

  .kicker {
    display: inline-block;
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--accent-dark);
    margin-bottom: 12px;
  }

  h2 {
    font-family: var(--serif);
    font-size: clamp(36px, 5vw, 64px);
    line-height: 1.1;
    letter-spacing: -0.02em;
    margin: 0;
    color: var(--ink);
  }

  .split {
    display: flex;
    flex-direction: column;
    gap: 32px;
  }

  // Two videos side-by-side with logo overlapping both at the seam.
  .videos {
    position: relative;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4px;
  }

  .vid {
    width: 100%;
    aspect-ratio: 16 / 10;
  }

  .vid-left { grid-column: 1; }
  .vid-right { grid-column: 2; }

  // Logo: absolutely centered over the seam, larger than the medallion was,
  // sitting visually above both videos via z-index.
  .logo {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    z-index: 2;
    width: clamp(140px, 22%, 280px);
    height: auto;
    pointer-events: none;
    user-select: none;
    filter: drop-shadow(0 4px 24px rgb(0 0 0 / 35%));
  }

  .captions {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 32px;
  }

  .side {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  h3 {
    font-family: var(--serif);
    font-size: clamp(24px, 3vw, 32px);
    margin: 0;
    color: var(--ink);
  }

  p {
    margin: 0;
    color: var(--ink-2);
    font-size: 16px;
    line-height: 1.55;
  }

  @media (width <= 720px) {
    .videos {
      grid-template-columns: 1fr;
      gap: 24px;
    }

    .vid-left,
    .vid-right {
      grid-column: 1;
    }

    .logo {
      // On stacked layout, drop the logo into a static row between the videos.
      position: static;
      transform: none;
      width: clamp(96px, 30%, 160px);
      margin: 0 auto;
      filter: drop-shadow(0 4px 16px rgb(0 0 0 / 25%));
    }

    .captions {
      grid-template-columns: 1fr;
    }

    .side {
      max-width: 480px;
      margin: 0 auto;
    }
  }
}
</style>
