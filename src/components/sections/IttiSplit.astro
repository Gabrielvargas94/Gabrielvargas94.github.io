---
import { Image } from 'astro:assets';
import VideoPlaceholder from '../ui/VideoPlaceholder.astro';
import Pill from '../ui/Pill.astro';
import ittiLogo from '../../../public/assets/itti-logo.png';
import type { Locale } from '../../lib/i18n';
import uiEn from '../../content/ui/en.json';
import uiEs from '../../content/ui/es.json';
import uiPt from '../../content/ui/pt.json';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const uiByLocale = { en: uiEn, es: uiEs, pt: uiPt } as const;
const ui = uiByLocale[locale];
const s = ui.sections.ittiSplit;
---
<section id="work" aria-labelledby="itti-split-title">
  <header class="head">
    <Pill variant="dark">{s.kicker}</Pill>
    <h2 id="itti-split-title">{s.title}</h2>
  </header>

  <div class="split">
    <article class="side">
      <div class="bg" aria-hidden="true">
        <VideoPlaceholder label={s.left} youtubeId="NG_xGUvlNl0" />
      </div>
      <div class="overlay">
        <h3>{s.left}</h3>
        <p>{s.leftDesc}</p>
      </div>
    </article>

    <Image
      class="logo"
      src={ittiLogo}
      alt="itti"
      widths={[180, 280, 420]}
      sizes="(max-width: 720px) 160px, 280px"
      loading="lazy"
      decoding="async"
    />

    <article class="side">
      <div class="bg" aria-hidden="true">
        <VideoPlaceholder label={s.right} tint="var(--accent-dark)" youtubeId="ffQv3wXQlEU" />
      </div>
      <div class="overlay">
        <h3>{s.right}</h3>
        <p>{s.rightDesc}</p>
      </div>
    </article>
  </div>

  <div class="what">
    <div class="what-inner">
      <aside class="what-label" aria-hidden="true">↳ {s.whatDidLabel}</aside>
      <div class="what-body">
        <p class="lede">{s.whatDidIntro}</p>
        <ol class="bullets">
          {s.bullets.map((b, i) => (
            <li>
              <span class="num">{String(i + 1).padStart(2, '0')}</span>
              <span class="bullet-text">{b}</span>
            </li>
          ))}
        </ol>
      </div>
    </div>
  </div>
</section>

<style lang="scss">
@layer components {
  section {
    background: var(--ink);
    color: var(--cream);
    padding: clamp(64px, 8vw, 100px) 0;
  }

  .head {
    text-align: center;
    max-width: 900px;
    margin: 0 auto clamp(32px, 5vw, 56px);
    padding: 0 clamp(16px, 4vw, 64px);
  }

  .kicker {
    display: inline-block;
    margin-bottom: 12px;
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--accent-light);
  }

  h2 {
    margin: 0;
    font-family: var(--serif);
    font-size: clamp(32px, 5vw, 56px);
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: var(--cream);
  }

  // Split: two full-bleed video sides edge-to-edge with logo overlay at seam.
  .split {
    position: relative;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2px;
    width: 100%;
    overflow: hidden;
  }

  .side {
    position: relative;
    isolation: isolate;
    min-height: clamp(420px, 60vh, 600px);
    overflow: hidden;
    background-color: #000000;
    display: flex;
  }

  // Video (or placeholder) fills the side as background.
  .bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  // Soft scrim across the whole video for mood.
  .bg::after {
    content: '';
    position: absolute;
    inset: 0;
    background: rgb(0 0 0 / 25%);
    pointer-events: none;
  }

  // Glass card containing the text. Anchored to the OUTER edge of each side
  // so the central itti logo never overlaps. Left side → card hugs left.
  // Right side → card hugs right (via :nth-of-type below).
  .overlay {
    position: relative;
    z-index: 1;
    align-self: flex-end;
    width: min(360px, 78%);
    margin: clamp(20px, 3vw, 40px);
    padding: clamp(20px, 2.4vw, 28px);
    background: rgb(20 16 12 / 78%);
    backdrop-filter: blur(14px) saturate(140%);
    -webkit-backdrop-filter: blur(14px) saturate(140%);
    border: 1px solid rgb(247 242 232 / 12%);
    border-radius: 16px;
    color: var(--cream);
    box-shadow: 0 18px 48px rgb(0 0 0 / 35%);
  }

  // Left card hugs left edge; right card hugs right edge.
  .side:nth-of-type(1) .overlay { margin-right: auto; }
  .side:nth-of-type(2) .overlay { margin-left: auto; }

  h3 {
    margin: 0 0 8px;
    font-family: var(--serif);
    font-size: clamp(24px, 2.6vw, 32px);
    line-height: 1.15;
    letter-spacing: -0.01em;
  }

  .overlay p {
    margin: 0;
    font-size: clamp(13.5px, 1.1vw, 15px);
    line-height: 1.55;
    color: rgb(247 242 232 / 90%);
  }

  // Logo absolutely centered over the seam, on top of both videos.
  .logo {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    z-index: 3;
    width: clamp(120px, 18%, 240px);
    height: auto;
    pointer-events: none;
    user-select: none;
    filter: drop-shadow(0 6px 28px rgb(0 0 0 / 55%));
  }

  // "What I did" — numbered bullets block below the split.
  .what {
    background: var(--cream);
    color: var(--ink);
    padding: clamp(64px, 8vw, 110px) clamp(16px, 4vw, 64px);
  }

  .what-inner {
    max-width: 1320px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: minmax(260px, 320px) 1fr;
    gap: clamp(32px, 5vw, 80px);
    align-items: start;
  }

  .what-label {
    padding-top: 6px;
    font-family: var(--mono);
    font-size: 12px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--ink-3);
  }

  .lede {
    margin: 0;
    max-width: 760px;
    font-family: var(--serif);
    font-size: clamp(22px, 2vw, 30px);
    line-height: 1.35;
    color: var(--ink);
    text-wrap: pretty;
  }

  .bullets {
    list-style: none;
    margin: clamp(28px, 4vw, 40px) 0 0;
    padding: 0;
    display: grid;
    gap: 18px;
  }

  .bullets li {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 16px;
    padding-top: 16px;
    border-top: 1px solid rgb(42 33 27 / 10%);
    font-size: 17px;
    line-height: 1.55;
    color: var(--ink-2);
  }

  .num {
    padding-top: 4px;
    font-family: var(--mono);
    font-size: 12px;
    color: var(--accent-dark);
  }

  // Mobile: stack the two sides vertically, logo static between them.
  @media (width <= 720px) {
    .split {
      grid-template-columns: 1fr;
      gap: 0;
    }

    .side {
      min-height: clamp(360px, 56vh, 480px);
    }

    .side:nth-of-type(1) .overlay,
    .side:nth-of-type(2) .overlay {
      width: calc(100% - 32px);
      margin: 16px;
    }

    .logo {
      // Place logo at the seam between stacked sides via static rendering.
      position: relative;
      top: auto;
      left: auto;
      transform: none;
      width: clamp(96px, 28%, 160px);
      margin: -28px auto;
      filter: drop-shadow(0 4px 16px rgb(0 0 0 / 50%));
    }

    .what-inner {
      grid-template-columns: 1fr;
    }
  }
}
</style>
